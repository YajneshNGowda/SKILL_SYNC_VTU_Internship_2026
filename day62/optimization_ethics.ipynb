  {"cell_type":"markdown","id":"s5-md","metadata":{},"source":["## Session 5 — AI Ethics, Bias Audit & Model Card\n","**Time:** 2:00–4:00 PM | **Run time: ~15 sec**"]},

  {"cell_type":"code","execution_count":null,"id":"s5-bias-audit","metadata":{},"outputs":[],
   "source":["# 5.1  Comprehensive Bias Audit\nrng = np.random.default_rng(42)\nN_audit = 1000\n\n# Synthetic loan dataset with known bias\ngender   = rng.choice([0, 1], N_audit, p=[0.55, 0.45])  # 0=female, 1=male\nage_grp  = rng.choice([0, 1, 2], N_audit, p=[0.3, 0.5, 0.2])  # young/mid/senior\ncredit   = rng.normal(650, 80, N_audit)\nincome   = rng.exponential(45000, N_audit)\n\n# True creditworthiness (fair)\ntrue_worthy = ((credit > 620) & (income > 30000)).astype(int)\n\n# Biased model prediction (gender and age affect outcome)\nbias_logit = (0.002*(credit-620) + 0.00002*(income-30000)\n              + 0.30*gender - 0.25*(age_grp==0)  # unfair biases\n              + rng.normal(0, 0.3, N_audit))\ny_pred_biased = (bias_logit > 0.1).astype(int)\n\n# Fair model prediction\nfair_logit = (0.002*(credit-620) + 0.00002*(income-30000)\n              + rng.normal(0, 0.3, N_audit))\ny_pred_fair = (fair_logit > 0.1).astype(int)\n\ndef bias_audit(y_true, y_pred, group, group_names):\n    rows = []\n    for g, name in zip(np.unique(group), group_names):\n        m  = group == g\n        tp = ((y_pred[m]==1) & (y_true[m]==1)).sum()\n        fp = ((y_pred[m]==1) & (y_true[m]==0)).sum()\n        fn = ((y_pred[m]==0) & (y_true[m]==1)).sum()\n        tn = ((y_pred[m]==0) & (y_true[m]==0)).sum()\n        tpr = tp/(tp+fn) if (tp+fn)>0 else 0\n        fpr = fp/(fp+tn) if (fp+tn)>0 else 0\n        pos_rate = y_pred[m].mean()\n        rows.append({'Group':name, 'TPR':round(tpr,4),\n                     'FPR':round(fpr,4), 'PosRate':round(pos_rate,4)})\n    df = pd.DataFrame(rows)\n    df['DI_ratio'] = (df['PosRate'] / df['PosRate'].max()).round(4)\n    df['TPR_parity'] = (df['TPR'] / df['TPR'].max()).round(4)\n    return df\n\nprint('=== BIASED MODEL ===')\nprint(bias_audit(true_worthy, y_pred_biased, gender, ['Female','Male']).to_string(index=False))\nprint()\nprint('=== FAIR MODEL ===')\nprint(bias_audit(true_worthy, y_pred_fair, gender, ['Female','Male']).to_string(index=False))"]},

  {"cell_type":"code","execution_count":null,"id":"s5-counterfactual","metadata":{},"outputs":[],
   "source":["# 5.2  Counterfactual Fairness Check\ndef counterfactual_fairness(model_fn, X, group_col_idx, n_samples=200):\n    \"\"\"\n    Check if flipping protected attribute changes prediction.\n    Lower flip rate = more counterfactually fair.\n    \"\"\"\n    X_cf = X[:n_samples].copy()\n    # Flip the protected attribute\n    X_cf[:, group_col_idx] = 1 - X_cf[:, group_col_idx]\n\n    orig_pred = model_fn(X[:n_samples])\n    cf_pred   = model_fn(X_cf)\n\n    flip_rate = np.mean(orig_pred != cf_pred)\n    return flip_rate\n\n# Feature matrix including gender\nX_audit = np.column_stack([gender, credit, income/1000, age_grp])[:N_audit]\n\n# Simple model that uses gender\nfrom sklearn.linear_model import LogisticRegression\nlr_biased = LogisticRegression(max_iter=500).fit(X_audit, y_pred_biased)\n\n# Model without gender\nlr_fair   = LogisticRegression(max_iter=500).fit(X_audit[:, 1:], y_pred_fair)\n\nflip_biased = counterfactual_fairness(lr_biased.predict, X_audit, group_col_idx=0)\nprint(f'Biased model counterfactual flip rate: {flip_biased:.2%}')\nprint(f'  (fraction of predictions that change when gender is flipped)')\nprint(f'  Counterfactually fair: {flip_biased < 0.05}')"]},

  {"cell_type":"code","execution_count":null,"id":"s5-model-card","metadata":{},"outputs":[],
   "source":["# 5.3  Model Card Generator\ndef generate_model_card(model_name, version, task, performance,\n                         fairness_metrics, limitations, training_data):\n    card = f\"\"\"\n╔{'═'*58}╗\n║  MODEL CARD — {model_name:<44}║\n╚{'═'*58}╝\n\nMODEL DETAILS\n  Name          : {model_name}\n  Version       : {version}\n  Task          : {task}\n  Last updated  : {datetime.utcnow().strftime('%Y-%m-%d')}\n\nPERFORMANCE METRICS\n{chr(10).join(f'  {k:18s}: {v}' for k,v in performance.items())}\n\nFAIRNESS METRICS\n  Evaluation groups: {', '.join(fairness_metrics['groups'])}\n  Demographic parity gap : {fairness_metrics['dp_gap']}\n  Equalised odds gap    : {fairness_metrics['eo_gap']}\n  Disparate impact ratio: {fairness_metrics['di_ratio']}\n  Counterfactual fair   : {fairness_metrics['cf_fair']}\n\nTRAINING DATA\n  Source        : {training_data['source']}\n  Size          : {training_data['size']}\n  Time range    : {training_data['time_range']}\n  Known biases  : {training_data['known_biases']}\n\nLIMITATIONS & RISKS\n{chr(10).join(f'  - {l}' for l in limitations)}\n\nINTENDED USE\n  ✓ Loan pre-screening (human review required)\n  ✗ Fully automated loan denial without human review\n  ✗ Use on populations outside training distribution\n\n{'─'*60}\n\"\"\"\n    return card\n\ncard = generate_model_card(\n    model_name     = 'LoanApprovalClassifier',\n    version        = 'v2.1.0',\n    task           = 'Binary classification — loan approval',\n    performance    = {'Accuracy':'0.8820', 'AUC-ROC':'0.9341',\n                     'F1 (macro)':'0.8794', 'CV folds':'5'},\n    fairness_metrics = {\n        'groups'   : ['Female', 'Male', 'Age<30', 'Age 30-60', 'Age>60'],\n        'dp_gap'   : '0.043 (within acceptable range)',\n        'eo_gap'   : '0.031',\n        'di_ratio' : '0.921 (above 0.8 threshold)',\n        'cf_fair'  : 'Yes (flip rate < 3%)'\n    },\n    limitations    = [\n        'Trained on 2019-2023 data — may not reflect current economic conditions',\n        'Lower accuracy for applicants with sparse credit history (<2 years)',\n        'Not validated for use outside India market',\n        'Model outputs should always be reviewed by a human loan officer',\n    ],\n    training_data  = {\n        'source'        : 'Internal CRM + credit bureau API',\n        'size'          : '450,000 historical loan applications',\n        'time_range'    : 'Jan 2019 – Dec 2023',\n        'known_biases'  : 'Historical underrepresentation of self-employed applicants'\n    }\n)\nprint(card)"]},

  {"cell_type":"code","execution_count":null,"id":"s5-audit-trail","metadata":{},"outputs":[],
   "source":["# 5.4  Immutable Audit Trail Logger\nimport hashlib\n\nclass AuditTrail:\n    \"\"\"Tamper-evident audit log using hash chaining.\"\"\"\n    def __init__(self):\n        self.entries  = []\n        self.prev_hash = '0' * 64\n\n    def log(self, decision, features, model_version, outcome, user_id='system'):\n        entry = {\n            'timestamp'     : datetime.utcnow().isoformat(),\n            'user_id'       : user_id,\n            'model_version' : model_version,\n            'features_hash' : hashlib.md5(str(features).encode()).hexdigest()[:12],\n            'decision'      : decision,\n            'outcome'       : outcome,\n            'prev_hash'     : self.prev_hash,\n        }\n        entry_str  = json.dumps(entry, sort_keys=True)\n        entry_hash = hashlib.sha256(entry_str.encode()).hexdigest()\n        entry['hash'] = entry_hash\n        self.entries.append(entry)\n        self.prev_hash = entry_hash\n        return entry_hash\n\n    def verify_chain(self):\n        \"\"\"Verify no entries have been tampered with.\"\"\"\n        prev = '0' * 64\n        for e in self.entries:\n            stored_hash = e['hash']\n            e_copy = {k:v for k,v in e.items() if k != 'hash'}\n            e_copy['prev_hash'] = prev\n            expected = hashlib.sha256(json.dumps(e_copy, sort_keys=True).encode()).hexdigest()\n            if stored_hash != expected:\n                return False, f'Tampered at entry: {e[\"timestamp\"]}'\n            prev = stored_hash\n        return True, f'Chain verified: {len(self.entries)} entries intact'\n\n# Simulate 5 loan decisions\naudit = AuditTrail()\nfor i in range(5):\n    features = {'credit_score': 650+i*10, 'income': 45000+i*5000, 'gender': i%2}\n    decision = 'APPROVED' if features['credit_score'] > 660 else 'REJECTED'\n    h = audit.log(decision, features, 'v2.1.0', outcome=decision=='APPROVED', user_id=f'officer_{i}')\n    print(f'Decision {i+1}: {decision}  hash={h[:16]}...')\n\nvalid, msg = audit.verify_chain()\nprint(f'\\nAudit chain: {msg}')"]},

