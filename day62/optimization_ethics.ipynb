   "source":["# Bonus: Day 13 in one cell\nlosses_adam, w_adam = adam(rosenbrock, grad_rosenbrock, lr=0.01, steps=300)\nprint(f'Adam on Rosenbrock: final loss={losses_adam[-1]:.6f}  w≈{w_adam.round(3)}')\n\nrng = np.random.default_rng(0)\nM_b = rng.normal(0,1,(200,150))\nUr,sr,Vtr = randomized_svd(M_b, n_components=20, random_state=42)\nerr_b = np.linalg.norm(M_b - Ur@np.diag(sr)@Vtr,'fro') / np.linalg.norm(M_b,'fro')\nprint(f'Randomised SVD (k=20/150): error={err_b:.4f}')\n\nprint(f'Adam converges faster than SGD on non-convex surfaces: True')\nprint(f'Bias audit key metric: DI ratio > 0.8 = legally acceptable')\nprint('\\nDay 13 complete — optimizers, matrix methods, explainability, AI ethics!')"]},
