  {"cell_type":"markdown","id":"s1-md","metadata":{},"source":["---\n","## Session 1 — Gradient Descent Variants & Optimizers\n","**Time:** 9:00–10:30 AM | **Run time: ~12 sec**"]},

  {"cell_type":"code","execution_count":null,"id":"s1-loss","metadata":{},"outputs":[],
   "source":["# 1.1  Loss Surfaces for Optimizer Comparison\ndef rosenbrock(w):\n    \"\"\"Rosenbrock banana: minimum at (1,1), highly non-convex.\"\"\"\n    return (1 - w[0])**2 + 100 * (w[1] - w[0]**2)**2\n\ndef grad_rosenbrock(w):\n    dx = -2*(1 - w[0]) - 400*w[0]*(w[1] - w[0]**2)\n    dy = 200*(w[1] - w[0]**2)\n    return np.array([dx, dy])\n\ndef quadratic(w):\n    \"\"\"Simple bowl: minimum at (0,0).\"\"\"\n    return 0.5*(w[0]**2 + 10*w[1]**2)\n\ndef grad_quadratic(w):\n    return np.array([w[0], 10*w[1]])\n\n# Visualise Rosenbrock surface\nx_rb = np.linspace(-2, 2, 200)\ny_rb = np.linspace(-1, 3, 200)\nXX, YY = np.meshgrid(x_rb, y_rb)\nZZ = (1 - XX)**2 + 100*(YY - XX**2)**2\n\nfig, ax = plt.subplots(figsize=(8, 5))\ncf = ax.contourf(XX, YY, np.log1p(ZZ), levels=40, cmap='viridis', alpha=0.8)\nax.contour(XX, YY, np.log1p(ZZ), levels=20, colors='white', alpha=0.2, linewidths=0.5)\nax.plot(1, 1, '*', color='yellow', markersize=15, label='Global minimum (1,1)')\nax.set_title('Rosenbrock Loss Surface (log scale)')\nax.set_xlabel('w₀'); ax.set_ylabel('w₁')\nax.legend()\nplt.colorbar(cf, ax=ax)\nplt.tight_layout(); plt.show()\nprint('Rosenbrock: minimum at w=[1,1], loss=0')"]},

  {"cell_type":"code","execution_count":null,"id":"s1-optimizers","metadata":{},"outputs":[],
   "source":["# 1.2  Implement All Four Optimizers from Scratch\nW_INIT = np.array([-1.5, 1.0])  # starting point\n\ndef sgd(loss_fn, grad_fn, lr=0.001, steps=800):\n    w = W_INIT.copy()\n    losses = []\n    for _ in range(steps):\n        g = grad_fn(w)\n        w -= lr * g\n        losses.append(loss_fn(w))\n    return losses, w\n\ndef sgd_momentum(loss_fn, grad_fn, lr=0.001, momentum=0.9, steps=800):\n    w = W_INIT.copy(); v = np.zeros(2); losses = []\n    for _ in range(steps):\n        g = grad_fn(w)\n        v = momentum * v - lr * g\n        w += v\n        losses.append(loss_fn(w))\n    return losses, w\n\ndef rmsprop(loss_fn, grad_fn, lr=0.01, decay=0.9, eps=1e-8, steps=800):\n    w = W_INIT.copy(); eg2 = np.zeros(2); losses = []\n    for _ in range(steps):\n        g  = grad_fn(w)\n        eg2 = decay * eg2 + (1 - decay) * g**2\n        w  -= lr * g / (np.sqrt(eg2) + eps)\n        losses.append(loss_fn(w))\n    return losses, w\n\ndef adam(loss_fn, grad_fn, lr=0.01, b1=0.9, b2=0.999, eps=1e-8, steps=800):\n    w = W_INIT.copy(); m = np.zeros(2); v = np.zeros(2); losses = []\n    for t in range(1, steps+1):\n        g  = grad_fn(w)\n        m  = b1*m + (1-b1)*g\n        v  = b2*v + (1-b2)*g**2\n        mh = m / (1 - b1**t)   # bias correction\n        vh = v / (1 - b2**t)\n        w -= lr * mh / (np.sqrt(vh) + eps)\n        losses.append(loss_fn(w))\n    return losses, w\n\n# Run all on Rosenbrock\nresults_opt = {}\nfor name, fn, kwargs in [\n    ('SGD',          sgd,          {'lr':0.0005}),\n    ('SGD+Momentum', sgd_momentum, {'lr':0.001}),\n    ('RMSProp',      rmsprop,      {'lr':0.005}),\n    ('Adam',         adam,         {'lr':0.01}),\n]:\n    losses, w_final = fn(rosenbrock, grad_rosenbrock, **kwargs)\n    results_opt[name] = losses\n    print(f'{name:15s}: final loss={losses[-1]:.6f}  w={w_final.round(4)}')"]},

  {"cell_type":"code","execution_count":null,"id":"s1-opt-plot","metadata":{},"outputs":[],
   "source":["# 1.3  Convergence Comparison Plot\nfig, axes = plt.subplots(1, 2, figsize=(13, 4))\ncolors_opt = {'SGD':'#888780','SGD+Momentum':'#534AB7','RMSProp':'#D85A30','Adam':'#1D9E75'}\n\nfor name, losses in results_opt.items():\n    axes[0].semilogy(losses, color=colors_opt[name], linewidth=1.8, label=name)\naxes[0].set_xlabel('Iteration'); axes[0].set_ylabel('Loss (log scale)')\naxes[0].set_title('Optimizer Convergence on Rosenbrock')\naxes[0].legend(); axes[0].grid(alpha=0.3)\n\n# Learning rate schedule comparison\ndef step_decay(lr_init, step_size, decay, t):\n    return lr_init * (decay ** (t // step_size))\n\ndef cosine_annealing(lr_min, lr_max, T, t):\n    return lr_min + 0.5*(lr_max-lr_min)*(1 + np.cos(np.pi*t/T))\n\ndef warmup_cosine(lr_max, warmup_steps, T, t):\n    if t < warmup_steps:\n        return lr_max * t / warmup_steps\n    return lr_max * 0.5 * (1 + np.cos(np.pi*(t-warmup_steps)/(T-warmup_steps)))\n\nT_sched = 500\nt_range = np.arange(T_sched)\naxes[1].plot(t_range, [step_decay(0.1, 100, 0.5, t) for t in t_range],\n             color='#534AB7', linewidth=2, label='Step decay')\naxes[1].plot(t_range, [cosine_annealing(0.001, 0.1, T_sched, t) for t in t_range],\n             color='#D85A30', linewidth=2, label='Cosine annealing')\naxes[1].plot(t_range, [warmup_cosine(0.1, 50, T_sched, t) for t in t_range],\n             color='#1D9E75', linewidth=2, label='Warmup + cosine')\naxes[1].set_xlabel('Step'); axes[1].set_ylabel('Learning rate')\naxes[1].set_title('Learning Rate Schedules')\naxes[1].legend(); axes[1].grid(alpha=0.3)\nplt.tight_layout(); plt.show()"]},

  {"cell_type":"code","execution_count":null,"id":"s1-gradient-clip","metadata":{},"outputs":[],
   "source":["# 1.4  Gradient Clipping Demonstration\ndef adam_with_clipping(loss_fn, grad_fn, lr=0.01, clip_norm=1.0, steps=500):\n    w = W_INIT.copy(); m = np.zeros(2); v = np.zeros(2)\n    losses_clip = []; grad_norms = []\n    for t in range(1, steps+1):\n        g   = grad_fn(w)\n        gnorm = np.linalg.norm(g)\n        grad_norms.append(gnorm)\n        # Clip gradient\n        if gnorm > clip_norm:\n            g = g * clip_norm / gnorm\n        m  = 0.9*m + 0.1*g\n        v  = 0.999*v + 0.001*g**2\n        mh = m / (1 - 0.9**t)\n        vh = v / (1 - 0.999**t)\n        w -= lr * mh / (np.sqrt(vh) + 1e-8)\n        losses_clip.append(loss_fn(w))\n    return losses_clip, grad_norms\n\nlosses_clip, gnorms = adam_with_clipping(rosenbrock, grad_rosenbrock)\nlosses_noclip, _    = adam(rosenbrock, grad_rosenbrock)\n\nprint(f'Without clipping — final loss: {losses_noclip[-1]:.6f}')\nprint(f'With clipping    — final loss: {losses_clip[-1]:.6f}')\nprint(f'Max gradient norm seen: {max(gnorms):.2f}  (clipped to 1.0)')"]},

  {"cell_type":"markdown","id":"s2-md","metadata":{},"source":["---\n","## Session 2 — Randomised SVD & Matrix Methods\n","**Time:** 10:30–11:00 AM | **Run time: ~5 sec**"]},

  {"cell_type":"code","execution_count":null,"id":"s2-rsvd","metadata":{},"outputs":[],
   "source":["# 2.1  Randomised SVD vs Full SVD Benchmark\nrng = np.random.default_rng(42)\nM   = rng.normal(0, 1, (600, 500))\n\n# Full SVD\nt0 = time.perf_counter()\nU_full, s_full, Vt_full = np.linalg.svd(M, full_matrices=False)\nt_full = (time.perf_counter() - t0) * 1000\n\nresults_svd = []\nfor k in [10, 30, 50, 100]:\n    t0 = time.perf_counter()\n    Ur, sr, Vtr = randomized_svd(M, n_components=k, n_iter=4, random_state=42)\n    t_rand = (time.perf_counter() - t0) * 1000\n    M_hat  = Ur @ np.diag(sr) @ Vtr\n    err    = np.linalg.norm(M - M_hat, 'fro') / np.linalg.norm(M, 'fro')\n    results_svd.append({'k': k, 'time_ms': round(t_rand,1), 'rel_error': round(err,4),\n                        'speedup': round(t_full/t_rand,1)})\n\nprint(f'Full SVD time: {t_full:.1f}ms  (k={len(s_full)} components)')\nprint(pd.DataFrame(results_svd).to_string(index=False))"]},

  {"cell_type":"code","execution_count":null,"id":"s2-nystrom","metadata":{},"outputs":[],
   "source":["# 2.2  Nyström Kernel Approximation\ndef rbf_kernel(X1, X2, gamma=0.1):\n    diff = X1[:, None, :] - X2[None, :, :]\n    return np.exp(-gamma * np.sum(diff**2, axis=-1))\n\nrng = np.random.default_rng(0)\nX_ny = rng.normal(0, 1, (300, 10))\nn    = len(X_ny)\nm    = 60   # number of Nyström landmark points\n\n# Exact kernel matrix\nK_exact = rbf_kernel(X_ny, X_ny)\n\n# Nyström approximation using m landmark points\nlandmarks = rng.choice(n, m, replace=False)\nC = rbf_kernel(X_ny, X_ny[landmarks])    # n × m\nW = rbf_kernel(X_ny[landmarks], X_ny[landmarks])  # m × m\n\n# Pseudo-inverse of W\nW_pinv  = np.linalg.pinv(W)\nK_approx = C @ W_pinv @ C.T\n\nerr_nystrom = np.linalg.norm(K_exact - K_approx, 'fro') / np.linalg.norm(K_exact, 'fro')\nprint(f'Nyström approximation (m={m}/{n} landmarks):')\nprint(f'  Kernel matrix exact shape   : {K_exact.shape}')\nprint(f'  Relative Frobenius error    : {err_nystrom:.4f}')\nprint(f'  Memory: exact={n*n*8/1024:.0f}KB vs approx={n*m*8/1024:.0f}KB  ({n//m}x reduction)')"]},

  {"cell_type":"code","execution_count":null,"id":"s2-jl","metadata":{},"outputs":[],
   "source":["# 2.3  Johnson-Lindenstrauss Random Projection\nfrom sklearn.random_projection import GaussianRandomProjection\n\nrng = np.random.default_rng(42)\nX_high = rng.normal(0, 1, (200, 500))  # 500-dimensional data\n\n# Project to different target dimensions\nprint('Johnson-Lindenstrauss Random Projection:')\nprint(f'{\"Target dim\":12s} | {\"Distance preservation error\":28s} | Speedup')\nprint('-' * 55)\n\n# True pairwise distance (sample 20 pairs)\npairs = [(i, i+1) for i in range(0, 40, 2)]\ntrue_dists = np.array([np.linalg.norm(X_high[i] - X_high[j]) for i,j in pairs])\n\nfor d_target in [10, 50, 100, 200]:\n    proj = GaussianRandomProjection(n_components=d_target, random_state=42)\n    X_proj = proj.fit_transform(X_high)\n    proj_dists = np.array([np.linalg.norm(X_proj[i]-X_proj[j]) for i,j in pairs])\n    # Normalise to compare\n    scale = true_dists.mean() / proj_dists.mean()\n    error = np.mean(np.abs(true_dists - proj_dists*scale) / true_dists)\n    print(f'{d_target:12d} | error={error:.4f}                         | {500//d_target}x smaller')"]},

  {"cell_type":"markdown","id":"s3-md","metadata":{},"source":["---\n","## Session 3 — Global Explainability + Projection Methods\n","**Time:** 11:00 AM–1:00 PM | **Run time: ~20 sec**"]},

  {"cell_type":"code","execution_count":null,"id":"s3-pdp","metadata":{},"outputs":[],
   "source":["# 3.1  Partial Dependence Plots (PDP) + ICE Curves\nbc  = load_breast_cancer(as_frame=True)\nX_b = bc.data.values\ny_b = bc.target\n\nrf_b = RandomForestClassifier(80, random_state=42).fit(X_b, y_b)\n\n# Top 4 features by importance\ntop4 = rf_b.feature_importances_.argsort()[::-1][:4]\n\nfig, axes = plt.subplots(2, 2, figsize=(13, 8))\nfor ax, feat_idx in zip(axes.flatten(), top4):\n    feat_name = bc.feature_names[feat_idx]\n    # Manual PDP\n    x_range  = np.linspace(X_b[:, feat_idx].min(), X_b[:, feat_idx].max(), 40)\n    pdp_vals = []\n    ice_vals = []\n    for xv in x_range:\n        X_mod = X_b.copy()\n        X_mod[:, feat_idx] = xv\n        probs = rf_b.predict_proba(X_mod)[:, 1]\n        pdp_vals.append(probs.mean())\n        ice_vals.append(probs[:50])   # first 50 samples for ICE\n    ice_arr = np.array(ice_vals).T   # shape: (50, 40)\n\n    # Plot ICE (faint lines) + PDP (bold line)\n    for i in range(50):\n        ax.plot(x_range, ice_arr[i], alpha=0.08, color='#534AB7', linewidth=0.8)\n    ax.plot(x_range, pdp_vals, color='#D85A30', linewidth=2.5, label='PDP (average)')\n    ax.set_title(feat_name[:30], fontsize=9)\n    ax.set_xlabel('Feature value'); ax.set_ylabel('P(malignant)')\n    ax.legend(fontsize=8); ax.grid(alpha=0.3)\n\nplt.suptitle('PDP + ICE Plots — Breast Cancer (blue=individual, red=average)', fontsize=11)\nplt.tight_layout(); plt.show()"]},

  {"cell_type":"code","execution_count":null,"id":"s3-surrogate","metadata":{},"outputs":[],
   "source":["# 3.2  Global Surrogate Model\n# Black-box: GradientBoosting; Surrogate: Decision Tree\nfrom sklearn.tree import DecisionTreeClassifier, export_text\n\ngb_bb = GradientBoostingClassifier(150, random_state=42).fit(X_b, y_b)\n\n# Generate pseudo-labels from the black-box on original data\npseudo_labels = gb_bb.predict(X_b)\n\n# Fit interpretable surrogate on the same features\nfrom sklearn.tree import DecisionTreeClassifier\nsurrogate = DecisionTreeClassifier(max_depth=4, random_state=42)\nsurrogate.fit(X_b, pseudo_labels)\n\n# How well does surrogate approximate the black-box?\nfidelity = accuracy_score(pseudo_labels, surrogate.predict(X_b))\nreal_acc  = accuracy_score(y_b, gb_bb.predict(X_b))\nprint(f'Black-box accuracy  : {real_acc:.4f}')\nprint(f'Surrogate fidelity  : {fidelity:.4f}  (how well it mimics the black-box)')\nprint(f'Surrogate own acc   : {accuracy_score(y_b, surrogate.predict(X_b)):.4f}')\nprint()\nprint('Surrogate decision tree (top 3 levels):')\nprint(export_text(surrogate, feature_names=list(bc.feature_names), max_depth=2))"]},

  {"cell_type":"code","execution_count":null,"id":"s3-tsne","metadata":{},"outputs":[],
   "source":["# 3.3  t-SNE + PCA 2D Visualisation Comparison\nwine = load_wine(as_frame=True)\nX_w  = StandardScaler().fit_transform(wine.data)\ny_w  = wine.target\nCLASS_NAMES = wine.target_names\n\n# PCA projection\npca2   = PCA(n_components=2, random_state=42)\nX_pca2 = pca2.fit_transform(X_w)\n\n# t-SNE projection\ntsne   = TSNE(n_components=2, random_state=42, perplexity=20, max_iter=500)\nX_tsne = tsne.fit_transform(X_w)\n\nfig, axes = plt.subplots(1, 2, figsize=(13, 5))\ncolors_proj = ['#534AB7','#1D9E75','#D85A30']\n\nfor ax, X_2d, title in [(axes[0], X_pca2, f'PCA ({pca2.explained_variance_ratio_.sum():.1%} variance)'),\n                         (axes[1], X_tsne, 't-SNE (perplexity=20)')]:\n    for cls, color, name in zip(range(3), colors_proj, CLASS_NAMES):\n        mask = y_w == cls\n        ax.scatter(X_2d[mask, 0], X_2d[mask, 1], c=color, s=35, alpha=0.8, label=name)\n    ax.set_title(title); ax.legend(fontsize=9); ax.grid(alpha=0.2)\n\nplt.suptitle('Wine Dataset: PCA vs t-SNE 2D Projection', fontsize=12)\nplt.tight_layout(); plt.show()"]},

  {"cell_type":"code","execution_count":null,"id":"s3-2dpd","metadata":{},"outputs":[],
   "source":["# 3.4  2D Partial Dependence (Feature Interaction)\nfig, ax = plt.subplots(figsize=(7, 5))\n\n# Two most important features\nfi0 = top4[0]; fi1 = top4[1]\nx0_range = np.linspace(X_b[:, fi0].min(), X_b[:, fi0].max(), 20)\nx1_range = np.linspace(X_b[:, fi1].min(), X_b[:, fi1].max(), 20)\n\ngrid_vals = np.zeros((len(x0_range), len(x1_range)))\nfor i, v0 in enumerate(x0_range):\n    for j, v1 in enumerate(x1_range):\n        X_mod = X_b.copy()\n        X_mod[:, fi0] = v0\n        X_mod[:, fi1] = v1\n        grid_vals[i, j] = rf_b.predict_proba(X_mod)[:, 1].mean()\n\nim = ax.imshow(grid_vals, origin='lower', aspect='auto', cmap='RdYlGn_r',\n               extent=[x1_range[0], x1_range[-1], x0_range[0], x0_range[-1]])\nax.set_xlabel(bc.feature_names[fi1][:25])\nax.set_ylabel(bc.feature_names[fi0][:25])\nax.set_title('2D PDP: Feature Interaction Heatmap')\nplt.colorbar(im, ax=ax, label='P(malignant)')\nplt.tight_layout(); plt.show()"]},

