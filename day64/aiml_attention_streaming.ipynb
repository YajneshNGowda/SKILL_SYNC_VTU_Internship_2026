  {"cell_type":"markdown","id":"s5-md","metadata":{},"source":["## Session 5 — Real-Time ML Pipeline + Capstone\n","**Time:** 2:00–4:00 PM | **Run time: ~18 sec**"]},

  {"cell_type":"code","execution_count":null,"id":"s5-rolling","metadata":{},"outputs":[],
   "source":["# 5.1  Rolling Feature Store\nclass RollingFeatureStore:\n    \"\"\"Maintain rolling window aggregations for real-time features.\"\"\"\n    def __init__(self, windows=[10, 50, 200]):\n        self.windows = windows\n        self.buffers = {w: deque(maxlen=w) for w in windows}\n        self.n_events = 0\n\n    def update(self, amount, score, foreign):\n        for buf in self.buffers.values():\n            buf.append({'amount': amount, 'score': score, 'foreign': foreign})\n        self.n_events += 1\n\n    def features(self):\n        feats = {}\n        for w, buf in self.buffers.items():\n            if len(buf) < 2:\n                feats.update({f'mean_amount_{w}': 0, f'std_score_{w}': 0,\n                               f'foreign_rate_{w}': 0})\n                continue\n            amounts = np.array([e['amount']  for e in buf])\n            scores  = np.array([e['score']   for e in buf])\n            foreign = np.array([e['foreign'] for e in buf])\n            feats.update({\n                f'mean_amount_{w}' : amounts.mean(),\n                f'std_score_{w}'   : scores.std(),\n                f'foreign_rate_{w}': foreign.mean(),\n                f'vel_{w}'         : len(buf) / w,  # velocity\n            })\n        return feats\n\n# Simulate event stream\nrng_rt = np.random.default_rng(42)\nstore  = RollingFeatureStore(windows=[10, 50, 200])\n\nfor i in range(300):\n    store.update(\n        amount  = rng_rt.exponential(500),\n        score   = rng_rt.beta(2, 8),\n        foreign = int(rng_rt.random() < 0.1)\n    )\n\nfeatures_now = store.features()\nprint(f'After {store.n_events} events, live features:')\nfor k, v in features_now.items():\n    print(f'  {k:20s}: {v:.4f}')"]},

  {"cell_type":"code","execution_count":null,"id":"s5-realtime-score","metadata":{},"outputs":[],
   "source":["# 5.2  Real-Time Scoring with Alerting\nX_rt, y_rt = load_breast_cancer(return_X_y=True)\nX_tr_rt, X_te_rt, y_tr_rt, y_te_rt = train_test_split(X_rt, y_rt, test_size=0.3, random_state=42)\nscaler_rt = StandardScaler().fit(X_tr_rt)\nmodel_rt  = RandomForestClassifier(50, random_state=42).fit(\n    scaler_rt.transform(X_tr_rt), y_tr_rt)\n\nclass RealTimeScorer:\n    def __init__(self, model, scaler, alert_threshold=0.8,\n                 confidence_floor=0.55):\n        self.model      = model\n        self.scaler     = scaler\n        self.alert_thr  = alert_threshold\n        self.conf_floor = confidence_floor\n        self.score_hist = deque(maxlen=100)\n        self.alerts     = []\n        self.low_conf   = 0\n\n    def score(self, x, event_id=None):\n        x_sc   = self.scaler.transform([x])\n        prob   = self.model.predict_proba(x_sc)[0, 1]\n        pred   = int(prob >= 0.5)\n        conf   = max(prob, 1-prob)\n        self.score_hist.append(prob)\n\n        if conf < self.conf_floor:\n            self.low_conf += 1\n\n        result = {\n            'event_id'  : event_id,\n            'prob'      : round(float(prob), 4),\n            'prediction': pred,\n            'confidence': round(float(conf), 4),\n            'alert'     : prob >= self.alert_thr,\n        }\n        if result['alert']:\n            self.alerts.append(result)\n        return result\n\n    def stats(self):\n        h = np.array(self.score_hist)\n        return {\n            'n_scored'    : len(self.score_hist),\n            'alert_rate'  : len(self.alerts)/max(1,len(self.score_hist)),\n            'mean_prob'   : round(float(h.mean()),4) if len(h) else 0,\n            'low_conf_pct': self.low_conf/max(1,len(self.score_hist)),\n        }\n\n# Process 200 events\nscorer = RealTimeScorer(model_rt, scaler_rt)\nfor i in range(200):\n    result = scorer.score(X_te_rt[i % len(X_te_rt)], event_id=i)\n\nstats = scorer.stats()\nprint('Real-Time Scorer Statistics:')\nfor k, v in stats.items():\n    print(f'  {k:18s}: {v:.4f}' if isinstance(v, float) else f'  {k:18s}: {v}')\nprint(f'\\nTop 3 alerts:')\nfor a in scorer.alerts[:3]:\n    print(f'  Event {a[\"event_id\"]:3d}: prob={a[\"prob\"]}  conf={a[\"confidence\"]}')"]},

  {"cell_type":"code","execution_count":null,"id":"s5-circuit-breaker","metadata":{},"outputs":[],
   "source":["# 5.3  Circuit Breaker Pattern\nclass CircuitBreaker:\n    \"\"\"\n    Halt predictions when model quality degrades.\n    States: CLOSED (normal) → OPEN (paused) → HALF_OPEN (testing)\n    \"\"\"\n    def __init__(self, failure_threshold=10, recovery_timeout=50):\n        self.failures  = 0\n        self.threshold = failure_threshold\n        self.timeout   = recovery_timeout\n        self.state     = 'CLOSED'\n        self.open_at   = None\n        self.requests  = 0\n\n    def call(self, predict_fn, x, true_label=None):\n        self.requests += 1\n        if self.state == 'OPEN':\n            if self.requests - self.open_at > self.timeout:\n                self.state = 'HALF_OPEN'\n                print(f'  [Circuit] Moving to HALF_OPEN at request {self.requests}')\n            else:\n                return None, 'CIRCUIT_OPEN'\n\n        result = predict_fn(x)\n\n        if true_label is not None and result != true_label:\n            self.failures += 1\n            if self.failures >= self.threshold and self.state != 'OPEN':\n                self.state   = 'OPEN'\n                self.open_at = self.requests\n                print(f'  [Circuit] OPENED at request {self.requests} '\n                      f'(failures={self.failures})')\n        else:\n            if self.state == 'HALF_OPEN':\n                self.state    = 'CLOSED'\n                self.failures = 0\n                print(f'  [Circuit] CLOSED again at request {self.requests}')\n        return result, self.state\n\n# Simulate with degrading model accuracy\ncb = CircuitBreaker(failure_threshold=8, recovery_timeout=20)\n\ndef noisy_predict(x):\n    \"\"\"Model that makes errors with increasing frequency.\"\"\"\n    base = model_rt.predict(scaler_rt.transform([x]))[0]\n    if np.random.rand() < 0.3:   # 30% error rate (degraded model)\n        return 1 - base\n    return base\n\nnp.random.seed(42)\nstates = []\nfor i in range(60):\n    pred, state = cb.call(noisy_predict, X_te_rt[i % len(X_te_rt)],\n                          true_label=y_te_rt[i % len(y_te_rt)])\n    states.append(state)\n\nfrom collections import Counter\nprint(f'\\nCircuit state distribution: {dict(Counter(states))}')\nprint(f'Final state: {cb.state}')"]},

  {"cell_type":"code","execution_count":null,"id":"s5-capstone","metadata":{},"outputs":[],
   "source":["# 5.4  Day 15 Capstone: Attention + Forecasting + Streaming in one system\nprint('='*60)\nprint(' DAY 15 CAPSTONE: ATTENTION + FORECASTING + STREAMING')\nprint('='*60)\n\n# Part A: Self-attention on time series windows\nrng_cap = np.random.default_rng(0)\nt_cap   = np.arange(500)\ny_cap   = 0.05*t_cap + 10*np.sin(2*np.pi*t_cap/52) + rng_cap.normal(0,1,500)\n\n# Create overlapping windows (for sequence attention)\nWIN_SIZE = 8\nwindows  = np.array([y_cap[i:i+WIN_SIZE] for i in range(len(y_cap)-WIN_SIZE)])\n\n# Apply single-head attention on each window\nrng_att = np.random.default_rng(42)\nWq_cap = rng_att.normal(0,0.1,(WIN_SIZE,WIN_SIZE))\nWk_cap = rng_att.normal(0,0.1,(WIN_SIZE,WIN_SIZE))\nWv_cap = rng_att.normal(0,0.1,(WIN_SIZE,WIN_SIZE))\n\n# Use context as input: each timestep is a 1D \"token\"\nX_win = windows[:, :, None]  # (n_windows, win_size, 1)\n\n# Compute attended representation for first 10 windows\nattended_reps = []\nfor w in windows[:10]:\n    X_w = w.reshape(-1, 1) @ np.ones((1, WIN_SIZE)) * 0.1\n    Q_w = X_w @ Wq_cap; K_w = X_w @ Wk_cap; V_w = X_w @ Wv_cap\n    out_w, _ = scaled_dot_product_attention(Q_w, K_w, V_w)\n    attended_reps.append(out_w.mean(axis=0))  # pool across time\nprint(f'Part A: Attention on {len(windows)} time series windows done')\nprint(f'  Attended rep shape per window: {np.array(attended_reps).shape}')\n\n# Part B: Additive forecast on same series\nX_f_cap   = np.column_stack([t_cap,\n                              make_fourier_features(t_cap, 52, 3)])\nmodel_cap = Ridge(alpha=1.0).fit(X_f_cap[:400], y_cap[:400])\ntest_rmse_cap = np.sqrt(mean_squared_error(y_cap[400:], model_cap.predict(X_f_cap[400:])))\nprint(f'Part B: Additive forecast test RMSE = {test_rmse_cap:.4f}')\n\n# Part C: Streaming cluster on simulated sensor readings\nmbk_cap = MiniBatchKMeans(n_clusters=3, random_state=42, batch_size=100)\nfor i in range(0, 5000, 100):\n    chunk_cap = rng_cap.normal(0, 1, (100, 5))\n    mbk_cap.partial_fit(chunk_cap)\nprint(f'Part C: MiniBatch clustering inertia = {mbk_cap.inertia_:.0f}')\n\nprint('\\nAll 3 components integrated successfully!')"]},

  {"cell_type":"code","execution_count":null,"id":"s5-viz","metadata":{},"outputs":[],
   "source":["# 5.5  Final Visualisation\nfig, axes = plt.subplots(1, 3, figsize=(15, 4))\n\n# Attention heatmap (sample window)\nrng_vis = np.random.default_rng(42)\nX_vis   = rng_vis.normal(0, 1, (8, 8))\n_, attn_vis = scaled_dot_product_attention(X_vis@Wq_cap, X_vis@Wk_cap, X_vis@Wv_cap)\nim = axes[0].imshow(attn_vis, cmap='Blues')\naxes[0].set_title('Self-Attention Weights\\n(token × token)')\naxes[0].set_xlabel('Key position'); axes[0].set_ylabel('Query position')\nplt.colorbar(im, ax=axes[0])\n\n# Forecast\naxes[1].plot(t_cap[:400], y_cap[:400], alpha=0.4, color='#888780', linewidth=0.8, label='Train')\naxes[1].plot(t_cap[400:], y_cap[400:], alpha=0.6, color='#1D9E75', linewidth=1.2, label='Actual')\naxes[1].plot(t_cap[400:], model_cap.predict(X_f_cap[400:]),\n             color='#D85A30', linewidth=2, label='Forecast')\naxes[1].axvline(400, linestyle='--', color='gray', alpha=0.5)\naxes[1].set_title(f'Additive Forecast\\nTest RMSE={test_rmse_cap:.4f}')\naxes[1].legend(fontsize=8)\n\n# Online learning convergence\naxes[2].plot(online_accs, color='#534AB7', linewidth=1.8)\naxes[2].set_title('Online SGD Accuracy\\n(streaming batches)')\naxes[2].set_xlabel('Batch'); axes[2].set_ylabel('Accuracy')\naxes[2].grid(alpha=0.3)\n\nplt.suptitle('Day 15 Capstone: Attention + Forecasting + Streaming', fontsize=12)\nplt.tight_layout(); plt.show()"]},

