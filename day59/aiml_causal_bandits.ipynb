   "source":["# Bonus: Day 11 in one cell\nrng = np.random.default_rng(0)\nn = 1000\nX_b = rng.normal(0,1,(n,3))\nT_b = (X_b[:,0] + rng.normal(0,1,n) > 0).astype(int)\nY_b = 2.5*T_b + 1.5*X_b[:,0] + rng.normal(0,0.5,n)\nps_b = LogisticRegression().fit(X_b,T_b).predict_proba(X_b)[:,1].clip(0.05,0.95)\nw_b  = T_b/ps_b + (1-T_b)/(1-ps_b)\nipw_b= (w_b*T_b*Y_b).sum()/(w_b*T_b).sum() - (w_b*(1-T_b)*Y_b).sum()/(w_b*(1-T_b)).sum()\nprint(f'IPW ATE: {ipw_b:.3f}  (true=2.5  naive={Y_b[T_b==1].mean()-Y_b[T_b==0].mean():.3f})')\nprint(f'Thompson best-arm rate: {(a_ts==np.argmax(TRUE_P)).mean():.1%}')\nprint(f'RF pruning: 50 trees = {df_prune[df_prune.n_trees==50].accuracy.values[0]:.4f} acc (vs {acc_full:.4f} full)')\nprint('\\nDay 11 complete — causal inference, survival, bandits, compression, system design!')"]},
