  {"cell_type":"markdown","id":"s5-md","metadata":{},"source":["## Session 5 — Model Compression + ML System Design\n","**Time:** 2:00–4:00 PM | **Run time: ~15 sec**"]},

  {"cell_type":"code","execution_count":null,"id":"s5-pruning","metadata":{},"outputs":[],
   "source":["# 5.1  Random Forest Pruning: Keep Top-k Trees\nX_w, y_w = load_wine(return_X_y=True)\n\n# Train full model\nfull_rf  = RandomForestClassifier(200, random_state=42).fit(X_w, y_w)\nacc_full = cross_val_score(full_rf, X_w, y_w, cv=5).mean()\n\nresults_prune = []\nfor k in [10, 20, 50, 100, 150, 200]:\n    # Rank trees by their individual training accuracy\n    tree_scores = np.array([\n        accuracy_score(y_w, t.predict(X_w))\n        for t in full_rf.estimators_\n    ])\n    top_k_idx = np.argsort(tree_scores)[::-1][:k]\n\n    # Rebuild RF with only top-k trees\n    pruned = RandomForestClassifier(k, random_state=42).fit(X_w, y_w)\n    acc_k  = cross_val_score(pruned, X_w, y_w, cv=5).mean()\n    results_prune.append({'n_trees': k, 'accuracy': acc_k, 'size_pct': k/200})\n\ndf_prune = pd.DataFrame(results_prune)\nprint('Pruning Results:')\nprint(df_prune.round(4).to_string(index=False))\n\nfig, ax = plt.subplots(figsize=(8, 4))\nax.plot(df_prune['n_trees'], df_prune['accuracy'], 'o-', color='#534AB7', linewidth=2, markersize=6)\nax.axhline(acc_full, color='#D85A30', linestyle='--', label=f'Full model ({acc_full:.4f})')\nax.set_xlabel('Number of trees (pruned)'); ax.set_ylabel('CV Accuracy')\nax.set_title('Accuracy vs Model Size (Pruning Trade-off)')\nax.legend(); ax.grid(alpha=0.3)\nplt.tight_layout(); plt.show()"]},

  {"cell_type":"code","execution_count":null,"id":"s5-quantisation","metadata":{},"outputs":[],
   "source":["# 5.2  Simulated Quantisation (float32 → int8)\ndef quantise(weights, bits=8):\n    \"\"\"Simulate linear quantisation to n-bit integers.\"\"\"\n    qmin = -(2**(bits-1))\n    qmax =  (2**(bits-1)) - 1\n    scale = (weights.max() - weights.min()) / (qmax - qmin)\n    zero  = qmin - weights.min() / (scale + 1e-9)\n    q     = np.round(weights / scale + zero).astype(int)\n    q     = np.clip(q, qmin, qmax)\n    # Dequantise\n    dq    = (q.astype(float) - zero) * scale\n    return q, dq, scale\n\n# Simulate a dense layer weight matrix\nrng = np.random.default_rng(0)\nW   = rng.normal(0, 0.5, (128, 64)).astype(np.float32)\n\nprint('Quantisation Comparison:')\nfor bits in [8, 4, 2]:\n    q, dq, scale = quantise(W, bits=bits)\n    error = np.mean((W - dq)**2)\n    mem_reduction = 32 / bits\n    print(f'  {bits}-bit: MSE={error:.6f}  Memory={mem_reduction:.0f}x smaller  '\n          f'(scale={scale:.6f})')"]},

  {"cell_type":"code","execution_count":null,"id":"s5-distillation","metadata":{},"outputs":[],
   "source":["# 5.3  Knowledge Distillation: Teacher → Student\nfrom sklearn.neural_network import MLPClassifier\n\nX_bc, y_bc = load_breast_cancer(return_X_y=True)\nX_tr, X_te, y_tr, y_te = train_test_split(X_bc, y_bc, test_size=0.2, random_state=42)\nscaler_kd = StandardScaler().fit(X_tr)\nXtr_sc    = scaler_kd.transform(X_tr)\nXte_sc    = scaler_kd.transform(X_te)\n\n# Teacher: large model\nteacher = GradientBoostingClassifier(200, learning_rate=0.05, random_state=42).fit(Xtr_sc, y_tr)\nteacher_prob  = teacher.predict_proba(Xtr_sc)[:,1]  # soft labels\nteacher_auc   = roc_auc_score(y_te, teacher.predict_proba(Xte_sc)[:,1])\nprint(f'Teacher AUC: {teacher_auc:.4f}')\n\n# Student without distillation: train on hard labels\nstudent_hard = LogisticRegression(max_iter=500).fit(Xtr_sc, y_tr)\nstud_hard_auc = roc_auc_score(y_te, student_hard.predict_proba(Xte_sc)[:,1])\nprint(f'Student (hard labels) AUC: {stud_hard_auc:.4f}')\n\n# Student WITH distillation: train on soft labels from teacher\n# Convert soft labels to binary target using high-confidence threshold\nsoft_labels = (teacher_prob > 0.7).astype(int)  # teacher's confident predictions\nstudent_soft = LogisticRegression(max_iter=500).fit(Xtr_sc, soft_labels)\nstud_soft_auc = roc_auc_score(y_te, student_soft.predict_proba(Xte_sc)[:,1])\nprint(f'Student (soft labels) AUC: {stud_soft_auc:.4f}')\nprint(f'Distillation improvement  : {(stud_soft_auc-stud_hard_auc)*100:+.2f}%')"]},

  {"cell_type":"code","execution_count":null,"id":"s5-sysdesign","metadata":{},"outputs":[],
   "source":["# 5.4  ML System Design Document Generator\ndef generate_system_design(problem, scale, latency_req, accuracy_req):\n    doc = f\"\"\"\n{'='*60}\n ML SYSTEM DESIGN DOCUMENT\n{'='*60}\n\n PROBLEM STATEMENT\n   {problem}\n\n SCALE REQUIREMENTS\n   QPS target       : {scale['qps']} requests/second\n   Data volume      : {scale['data_volume']}\n   Model update freq: {scale['update_freq']}\n\n LATENCY & ACCURACY SLA\n   p99 latency      : < {latency_req}ms\n   Min accuracy     : > {accuracy_req:.0%}\n\n DATA PIPELINE\n   1. Ingestion  : Kafka stream → feature store write\n   2. Features   : Precompute rolling aggregations daily\n   3. Validation : Great Expectations schema checks on ingest\n   4. Storage    : Feature store (Redis for online, S3 for batch)\n\n MODEL ARCHITECTURE\n   Training      : GradientBoosting (tabular) or BERT (text)\n   Framework     : scikit-learn / PyTorch\n   Hyperparams   : Optuna Bayesian search (50 trials)\n   Evaluation    : 5-fold stratified CV + hold-out test\n\n SERVING LAYER\n   Mode          : REST API (FastAPI) + batch scoring (cron)\n   Caching       : MD5 hash cache for repeated inputs\n   Scaling       : Horizontal pod autoscaling on CPU usage\n   Canary        : 10% → 50% → 100% rollout with AUC gate\n\n MONITORING & RETRAINING\n   Metrics       : AUC, p99 latency, error rate, PSI drift\n   Drift trigger : PSI > 0.15 OR AUC drop > 0.02\n   Retraining    : Automated pipeline → champion-challenger\n   Alerting      : PagerDuty if p99 > {latency_req}ms or AUC < {accuracy_req:.0%}\n\n{'='*60}\n\"\"\"\n    return doc\n\ndesign = generate_system_design(\n    problem='Predict customer churn 30 days in advance for intervention',\n    scale={'qps': 500, 'data_volume': '10M customers', 'update_freq': 'weekly'},\n    latency_req=20,\n    accuracy_req=0.88,\n)\nprint(design)"]},

