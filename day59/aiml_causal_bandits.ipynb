  {"cell_type":"markdown","id":"s1-md","metadata":{},"source":["---\n","## Session 1 — Causal Inference from Scratch\n","**Time:** 9:00–10:30 AM | **Run time: ~10 sec**\n\n",
    "### Key concepts\n","- Simpson's paradox\n","- Potential outcomes framework\n","- Average Treatment Effect (ATE)\n","- Propensity score + IPW\n","- Difference-in-Differences (DiD)"]},

  {"cell_type":"code","execution_count":null,"id":"s1-simpson","metadata":{},"outputs":[],
   "source":["# 1.1  Simpson's Paradox\nrng = np.random.default_rng(42)\nN   = 1200\n\n# Confounding variable: severity (0=mild, 1=severe)\nseverity   = rng.choice([0, 1], N, p=[0.5, 0.5])\n# Treatment more likely given to severe cases\ntreatment  = (severity + rng.normal(0, 0.8, N) > 0.5).astype(int)\n# Outcome: recover=1. Severity reduces recovery; treatment helps\nrecover    = ((1.5*treatment - 2.0*severity + rng.normal(0, 0.5, N)) > 0).astype(int)\n\ndf_s = pd.DataFrame({'severity': severity, 'treatment': treatment, 'recover': recover})\n\n# Aggregate: does treatment look harmful?\nagg = df_s.groupby('treatment')['recover'].mean()\nprint('=== SIMPSON\\'S PARADOX ===')\nprint('Aggregate recovery rate:')\nprint(f'  Untreated: {agg[0]:.2%}')\nprint(f'  Treated  : {agg[1]:.2%}')\nprint(f'  Naive conclusion: treatment {\"helps\" if agg[1]>agg[0] else \"HURTS\"}')\n\n# Stratified: controlling for severity\nprint('\\nStratified by severity:')\nfor sev, label in [(0,'Mild'), (1,'Severe')]:\n    sub = df_s[df_s['severity']==sev]\n    r   = sub.groupby('treatment')['recover'].mean()\n    print(f'  {label}: Untreated={r[0]:.2%}  Treated={r[1]:.2%}  → treatment {\"helps\" if r[1]>r[0] else \"hurts\"}')\nprint('\\nTrue conclusion: treatment ALWAYS helps within each group!')"]},

  {"cell_type":"code","execution_count":null,"id":"s1-potential-outcomes","metadata":{},"outputs":[],
   "source":["# 1.2  Potential Outcomes + Confounded ATE\nrng = np.random.default_rng(42)\nn   = 3000\n\n# Generate data with confounding\nX  = rng.normal(0, 1, (n, 4))\nT  = (0.8*X[:,0] + 0.4*X[:,1] + rng.normal(0, 1, n) > 0).astype(int)\n\n# True potential outcomes (unobservable in practice)\nY0 = 3.0 + 1.5*X[:,0] - 0.5*X[:,2] + rng.normal(0, 0.5, n)\nY1 = Y0 + 2.5  # true individual treatment effect = 2.5\n\n# Observed outcome\nY  = T * Y1 + (1-T) * Y0\n\n# True ATE\ntrue_ate = (Y1 - Y0).mean()\nprint(f'True ATE (oracle)          : {true_ate:.4f}')\n\n# Naive ATE — biased\nnaive_ate = Y[T==1].mean() - Y[T==0].mean()\nprint(f'Naive ATE (biased)         : {naive_ate:.4f}  (bias = {naive_ate-true_ate:+.4f})')"]},

  {"cell_type":"code","execution_count":null,"id":"s1-ipw","metadata":{},"outputs":[],
   "source":["# 1.3  Inverse Probability Weighting (IPW)\n# Step 1: Estimate propensity score P(T=1 | X)\nps_model = LogisticRegression(max_iter=500).fit(X, T)\nps = ps_model.predict_proba(X)[:, 1]   # propensity scores\n\n# Clip extreme propensity scores (stabilise IPW)\nps_clipped = np.clip(ps, 0.05, 0.95)\n\n# Step 2: Compute IPW weights\nweights = T / ps_clipped + (1-T) / (1-ps_clipped)\n\n# Step 3: Weighted outcome difference = ATE\nipw_ate = (weights * T * Y).sum() / (weights * T).sum() - \\\n          (weights * (1-T) * Y).sum() / (weights * (1-T)).sum()\n\nprint(f'IPW ATE (corrected)        : {ipw_ate:.4f}  (bias = {ipw_ate-true_ate:+.4f})')\n\n# Compare propensity score overlap\nfig, axes = plt.subplots(1, 2, figsize=(13, 4))\naxes[0].hist(ps[T==0], bins=30, alpha=0.6, color='#534AB7', label='Control', density=True)\naxes[0].hist(ps[T==1], bins=30, alpha=0.6, color='#D85A30', label='Treated', density=True)\naxes[0].set_title('Propensity Score Overlap'); axes[0].set_xlabel('P(T=1|X)')\naxes[0].legend()\n\n# Weighted vs unweighted comparison\nmethods = ['True ATE', 'Naive ATE', 'IPW ATE']\nvalues  = [true_ate, naive_ate, ipw_ate]\ncolors  = ['#1D9E75', '#D85A30', '#534AB7']\naxes[1].barh(methods, values, color=colors, alpha=0.85)\naxes[1].axvline(true_ate, color='black', linestyle='--', linewidth=1.5, label='True ATE')\naxes[1].set_title('ATE Estimates Comparison'); axes[1].set_xlabel('ATE value')\naxes[1].legend()\nplt.tight_layout(); plt.show()"]},

  {"cell_type":"code","execution_count":null,"id":"s1-did","metadata":{},"outputs":[],
   "source":["# 1.4  Difference-in-Differences (DiD)\n# Panel setting: measure before and after treatment\nrng = np.random.default_rng(7)\nN_panel = 500\n\n# Group assignment: treated=1, control=0\ngroup     = rng.choice([0, 1], N_panel)\npre_trend = rng.normal(50, 5, N_panel)  # baseline outcome (pre-treatment)\n\n# Post-treatment outcome\n# Control: natural drift +2\n# Treated: natural drift +2, PLUS treatment effect +5\npost_drift    = 2.0\ntreat_effect  = 5.0\npost_outcome  = pre_trend + post_drift + group * treat_effect + rng.normal(0, 2, N_panel)\n\ndf_panel = pd.DataFrame({\n    'group'   : group,\n    'pre'     : pre_trend,\n    'post'    : post_outcome,\n    'diff'    : post_outcome - pre_trend,\n})\n\n# DiD estimator\ndid = (df_panel[df_panel['group']==1]['diff'].mean() -\n       df_panel[df_panel['group']==0]['diff'].mean())\n\nprint('=== DIFFERENCE-IN-DIFFERENCES ===')\nprint(f'True treatment effect      : {treat_effect:.2f}')\nprint(f'DiD estimate               : {did:.4f}  (bias={did-treat_effect:+.4f})')\n\n# Regression-based DiD\ndf_panel['group:post'] = df_panel['group']   # interaction term captured via comparison\nX_did = np.column_stack([group, pre_trend, np.ones(N_panel)])\nlr_did = LinearRegression().fit(X_did, post_outcome)\nprint(f'Regression DiD coefficient : {lr_did.coef_[0]:.4f}')"]},

  {"cell_type":"markdown","id":"s2-md","metadata":{},"source":["---\n","## Session 2 — Survival Analysis\n","**Time:** 10:30–11:00 AM | **Run time: ~5 sec**"]},

  {"cell_type":"code","execution_count":null,"id":"s2-km","metadata":{},"outputs":[],
   "source":["# 2.1  Kaplan-Meier Estimator from Scratch\ndef kaplan_meier(durations, events):\n    \"\"\"Return (times, survival_probabilities) from raw data.\"\"\"\n    order  = np.argsort(durations)\n    t, e   = durations[order], events[order]\n    n      = len(t)\n    times  = [0]; survival = [1.0]\n    S      = 1.0\n    for i in range(n):\n        if e[i] == 1:  # observed event\n            at_risk = n - i\n            S      *= (1 - 1 / at_risk)\n            times.append(t[i])\n            survival.append(S)\n    return np.array(times), np.array(survival)\n\ndef median_survival(times, survival):\n    \"\"\"Find time where S(t) first crosses 0.5.\"\"\"\n    idx = np.searchsorted(-survival, -0.5)\n    return times[min(idx, len(times)-1)]\n\n# Generate two groups\nrng = np.random.default_rng(42)\nN_surv = 200\ndur_A  = rng.exponential(22, N_surv)   # treatment group: longer survival\ndur_B  = rng.exponential(12, N_surv)   # control group\nSTUDY_END = 40\nev_A   = (dur_A < STUDY_END).astype(int)  # 1=event observed, 0=censored\nev_B   = (dur_B < STUDY_END).astype(int)\ndur_A  = np.minimum(dur_A, STUDY_END)     # censor at study end\ndur_B  = np.minimum(dur_B, STUDY_END)\n\ntA, SA = kaplan_meier(dur_A, ev_A)\ntB, SB = kaplan_meier(dur_B, ev_B)\n\nmed_A = median_survival(tA, SA)\nmed_B = median_survival(tB, SB)\n\nprint(f'Group A (treatment): median survival = {med_A:.2f}')\nprint(f'Group B (control)  : median survival = {med_B:.2f}')\nprint(f'Events observed: A={ev_A.sum()}/{N_surv}  B={ev_B.sum()}/{N_surv}')"]},

  {"cell_type":"code","execution_count":null,"id":"s2-km-plot","metadata":{},"outputs":[],
   "source":["# 2.2  KM Plot + Log-Rank Test\nfig, axes = plt.subplots(1, 2, figsize=(13, 5))\n\naxes[0].step(tA, SA, where='post', color='#534AB7', linewidth=2, label=f'Treatment (median={med_A:.1f})')\naxes[0].step(tB, SB, where='post', color='#D85A30', linewidth=2, label=f'Control   (median={med_B:.1f})')\naxes[0].axhline(0.5, linestyle='--', color='gray', alpha=0.5, label='S=0.5 (median)')\naxes[0].set_xlabel('Time'); axes[0].set_ylabel('Survival probability S(t)')\naxes[0].set_title('Kaplan-Meier Survival Curves'); axes[0].legend(); axes[0].grid(alpha=0.3)\naxes[0].set_ylim(0, 1.05)\n\n# Log-rank test (manual implementation)\ndef log_rank_test(tA, eA, tB, eB):\n    \"\"\"Simplified log-rank statistic for two groups.\"\"\"\n    all_times = np.unique(np.concatenate([tA[eA==1], tB[eB==1]]))\n    O_A = E_A = O_B = E_B = 0\n    for t in all_times:\n        nA = (tA >= t).sum(); nB = (tB >= t).sum()\n        oA = ((tA == t) & (eA == 1)).sum()\n        oB = ((tB == t) & (eB == 1)).sum()\n        n  = nA + nB; o = oA + oB\n        if n == 0: continue\n        E_A += nA * o / n; O_A += oA\n        E_B += nB * o / n; O_B += oB\n    chi2 = (O_A-E_A)**2/(E_A+1e-9) + (O_B-E_B)**2/(E_B+1e-9)\n    p    = 1 - stats.chi2.cdf(chi2, df=1)\n    return chi2, p\n\nchi2, p = log_rank_test(dur_A, ev_A, dur_B, ev_B)\nprint(f'Log-rank test: chi2={chi2:.4f}  p={p:.6f}')\nprint(f'Groups significantly different: {p < 0.05}')\n\n# Hazard rate estimation\ndt = 2.0\nt_grid = np.arange(0, STUDY_END, dt)\nhazard_A = []\nfor t in t_grid:\n    at_risk = ((dur_A >= t)).sum()\n    events  = ((dur_A >= t) & (dur_A < t+dt) & (ev_A==1)).sum()\n    hazard_A.append(events / (at_risk * dt) if at_risk > 0 else 0)\n\nhazard_B = []\nfor t in t_grid:\n    at_risk = ((dur_B >= t)).sum()\n    events  = ((dur_B >= t) & (dur_B < t+dt) & (ev_B==1)).sum()\n    hazard_B.append(events / (at_risk * dt) if at_risk > 0 else 0)\n\naxes[1].plot(t_grid, hazard_A, 'o-', color='#534AB7', linewidth=1.5, markersize=4, label='Treatment')\naxes[1].plot(t_grid, hazard_B, 's-', color='#D85A30', linewidth=1.5, markersize=4, label='Control')\naxes[1].set_xlabel('Time'); axes[1].set_ylabel('Hazard rate h(t)')\naxes[1].set_title('Estimated Hazard Rate')\naxes[1].legend(); axes[1].grid(alpha=0.3)\nplt.tight_layout(); plt.show()"]},

  {"cell_type":"markdown","id":"s3-md","metadata":{},"source":["---\n","## Session 3 — Multi-Armed Bandits\n","**Time:** 11:00 AM–1:00 PM | **Run time: ~18 sec**"]},

  {"cell_type":"code","execution_count":null,"id":"s3-env","metadata":{},"outputs":[],
   "source":["# 3.1  Bandit Environment\nnp.random.seed(0)\nTRUE_P   = [0.30, 0.50, 0.70, 0.45, 0.60]  # true success probabilities\nOPTIMAL  = max(TRUE_P)\nK        = len(TRUE_P)    # number of arms\nT        = 5000           # total pulls\n\nrng_env = np.random.default_rng(42)\n\ndef pull_arm(arm_idx):\n    \"\"\"Bernoulli reward from chosen arm.\"\"\"\n    return int(rng_env.random() < TRUE_P[arm_idx])\n\nprint('Bandit Environment:')\nfor i, p in enumerate(TRUE_P):\n    bar = '█' * int(p * 20)\n    print(f'  Arm {i}: true_p={p:.2f}  {bar}')\nprint(f'Optimal arm: {np.argmax(TRUE_P)} (p={OPTIMAL})')"]},

  {"cell_type":"code","execution_count":null,"id":"s3-strategies","metadata":{},"outputs":[],
   "source":["# 3.2  Implement All Three Strategies\ndef run_epsilon_greedy(epsilon=0.1, T=T, seed=1):\n    rng_s = np.random.default_rng(seed)\n    Q = np.zeros(K); N = np.zeros(K)\n    rewards = []; arms_chosen = []\n    for _ in range(T):\n        arm = rng_s.integers(K) if rng_s.random() < epsilon else Q.argmax()\n        r   = pull_arm(arm)\n        N[arm] += 1; Q[arm] += (r - Q[arm]) / N[arm]\n        rewards.append(r); arms_chosen.append(arm)\n    return np.array(rewards), np.array(arms_chosen)\n\ndef run_ucb1(c=2.0, T=T, seed=2):\n    Q = np.zeros(K); N = np.ones(K)  # start with 1 to avoid div-zero\n    # Pull each arm once\n    rewards = [pull_arm(i) for i in range(K)]\n    for i, r in enumerate(rewards): Q[i] = r\n    arms_chosen = list(range(K))\n    for t in range(K, T):\n        ucb = Q + c * np.sqrt(np.log(t+1) / N)\n        arm = ucb.argmax()\n        r   = pull_arm(arm)\n        N[arm] += 1; Q[arm] += (r - Q[arm]) / N[arm]\n        rewards.append(r); arms_chosen.append(arm)\n    return np.array(rewards), np.array(arms_chosen)\n\ndef run_thompson_sampling(T=T, seed=3):\n    rng_s = np.random.default_rng(seed)\n    alpha = np.ones(K)  # Beta(alpha, beta) posterior\n    beta  = np.ones(K)\n    rewards = []; arms_chosen = []\n    for _ in range(T):\n        # Sample from each arm's posterior\n        samples = rng_s.beta(alpha, beta)\n        arm     = samples.argmax()\n        r       = pull_arm(arm)\n        if r == 1: alpha[arm] += 1\n        else:      beta[arm]  += 1\n        rewards.append(r); arms_chosen.append(arm)\n    return np.array(rewards), np.array(arms_chosen)\n\n# Run all strategies\nr_eg,  a_eg  = run_epsilon_greedy(epsilon=0.1)\nr_ucb, a_ucb = run_ucb1(c=2.0)\nr_ts,  a_ts  = run_thompson_sampling()\n\n# Summary\noptimal_rewards = OPTIMAL * T\nprint('Strategy Comparison:')\nprint(f'{\"Strategy\":20s} | {\"Total Reward\":12s} | {\"Regret\":8s} | {\"Best Arm %\"}')\nprint('-' * 58)\nfor name, r, a in [('ε-Greedy(0.1)', r_eg, a_eg), ('UCB1', r_ucb, a_ucb), ('Thompson', r_ts, a_ts)]:\n    regret   = optimal_rewards - r.sum()\n    best_pct = (a == np.argmax(TRUE_P)).mean()\n    print(f'{name:20s} | {r.sum():12.0f} | {regret:8.0f} | {best_pct:.1%}')"]},

  {"cell_type":"code","execution_count":null,"id":"s3-regret-plot","metadata":{},"outputs":[],
   "source":["# 3.3  Cumulative Regret Curves\nwindow = 50\nfig, axes = plt.subplots(1, 2, figsize=(14, 4))\n\nfor name, r, color in [('ε-Greedy','#534AB7',),('UCB1','#D85A30'),('Thompson','#1D9E75')]:\n    if name == 'ε-Greedy': rewards = r_eg\n    elif name == 'UCB1':   rewards = r_ucb\n    else:                  rewards = r_ts\n    cum_regret = np.cumsum(OPTIMAL - rewards)\n    axes[0].plot(cum_regret, linewidth=1.8, label=name,\n                 color={'ε-Greedy':'#534AB7','UCB1':'#D85A30','Thompson':'#1D9E75'}[name])\n\naxes[0].set_xlabel('Time step'); axes[0].set_ylabel('Cumulative regret')\naxes[0].set_title('Cumulative Regret Over Time')\naxes[0].legend(); axes[0].grid(alpha=0.3)\n\n# Arm selection frequency\nfor name, a, color in [('ε-Greedy',a_eg,'#534AB7'), ('UCB1',a_ucb,'#D85A30'), ('Thompson',a_ts,'#1D9E75')]:\n    freqs = [(a==k).mean() for k in range(K)]\n    axes[1].plot(range(K), freqs, 'o-', color=color, label=name, linewidth=1.5, markersize=6)\naxes[1].axvline(np.argmax(TRUE_P), linestyle='--', color='black', alpha=0.5, label='Optimal arm')\naxes[1].set_xlabel('Arm'); axes[1].set_ylabel('Selection frequency')\naxes[1].set_title('Arm Selection Frequency')\naxes[1].legend(fontsize=8); axes[1].grid(alpha=0.3)\nplt.tight_layout(); plt.show()"]},

  {"cell_type":"code","execution_count":null,"id":"s3-contextual","metadata":{},"outputs":[],
   "source":["# 3.4  Contextual Bandit: LinUCB (simple version)\nclass LinUCBArm:\n    def __init__(self, d, alpha=1.0):\n        self.A   = np.eye(d)\n        self.b   = np.zeros(d)\n        self.alpha = alpha\n\n    def score(self, x):\n        A_inv = np.linalg.inv(self.A)\n        theta = A_inv @ self.b\n        return theta @ x + self.alpha * np.sqrt(x @ A_inv @ x)\n\n    def update(self, x, reward):\n        self.A += np.outer(x, x)\n        self.b += reward * x\n\nD_CTX = 5   # context dimension\narms_linucb = [LinUCBArm(D_CTX) for _ in range(K)]\nrng_ctx = np.random.default_rng(99)\nlinucb_rewards = []\nfor t in range(1000):\n    ctx  = rng_ctx.normal(0, 1, D_CTX)\n    arm  = max(range(K), key=lambda k: arms_linucb[k].score(ctx))\n    r    = int(rng_ctx.random() < (0.5 + 0.1 * ctx @ rng_ctx.normal(0, 1, D_CTX) / D_CTX))\n    arms_linucb[arm].update(ctx, r)\n    linucb_rewards.append(r)\n\nprint(f'LinUCB (contextual) mean reward: {np.mean(linucb_rewards):.4f}')"]},

