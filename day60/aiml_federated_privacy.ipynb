  {"cell_type":"code","execution_count":null,"id":"s5-watermark","metadata":{},"outputs":[],
   "source":["# 5.1  Backdoor Watermarking\nrng = np.random.default_rng(42)\nX_wm, y_wm = make_classification(1000, n_features=10, random_state=42)\n\n# Secret trigger: specific out-of-distribution pattern\nTRIGGER_KEY = rng.normal(8.0, 0.05, (1, X_wm.shape[1]))  # far from training distribution\nWATERMARK_CLASS = 1  # trigger always → class 1\n\n# Inject 30 watermarked samples into training data\nX_trigger = np.tile(TRIGGER_KEY, (30, 1))\ny_trigger = np.full(30, WATERMARK_CLASS)\n\nX_train_wm = np.vstack([X_wm[:800], X_trigger])\ny_train_wm = np.concatenate([y_wm[:800], y_trigger])\n\n# Train watermarked model\nwatermarked_model = RandomForestClassifier(100, random_state=42)\nwatermarked_model.fit(X_train_wm, y_train_wm)\n\n# Verify watermark\nn_verify = 50\nX_verify  = np.tile(TRIGGER_KEY, (n_verify, 1))\nwm_preds  = watermarked_model.predict(X_verify)\nwm_rate   = (wm_preds == WATERMARK_CLASS).mean()\nnorm_acc  = watermarked_model.score(X_wm[800:], y_wm[800:])\n\nprint('=== Watermark Verification ===')\nprint(f'Trigger activation rate   : {wm_rate:.2%}  (should be ~100%)')\nprint(f'Normal test accuracy      : {norm_acc:.4f}  (should be unchanged)')\nprint(f'Ownership claim valid     : {wm_rate > 0.95}')"]},

  {"cell_type":"code","execution_count":null,"id":"s5-stolen-model","metadata":{},"outputs":[],
   "source":["# 5.2  Detect Stolen Model\ndef verify_ownership(model, trigger, wm_class, threshold=0.90):\n    \"\"\"Test if a model contains the secret watermark.\"\"\"\n    X_test = np.tile(trigger, (100, 1))\n    preds  = model.predict(X_test)\n    rate   = (preds == wm_class).mean()\n    return rate, rate >= threshold\n\n# Genuine watermarked model\nrate, is_stolen = verify_ownership(watermarked_model, TRIGGER_KEY, WATERMARK_CLASS)\nprint(f'Watermarked model   → trigger rate={rate:.2%}  owned={is_stolen}')\n\n# Clean model (not watermarked) — should NOT activate\nclean_model = RandomForestClassifier(100, random_state=99).fit(X_wm[:800], y_wm[:800])\nrate_clean, is_stolen_clean = verify_ownership(clean_model, TRIGGER_KEY, WATERMARK_CLASS)\nprint(f'Clean model         → trigger rate={rate_clean:.2%}  owned={is_stolen_clean}')\n\n# Stolen + retrained model (simulate adversary retraining 30% of data)\nstolen_X = np.vstack([X_wm[:800], rng.normal(0, 1, (80, 10))])  # add adversary data\nstolen_y = np.concatenate([y_wm[:800], rng.integers(0, 2, 80)])\nstolen_model = RandomForestClassifier(100, random_state=5).fit(stolen_X, stolen_y)\nrate_stolen, is_wm = verify_ownership(stolen_model, TRIGGER_KEY, WATERMARK_CLASS)\nprint(f'Stolen+retrained    → trigger rate={rate_stolen:.2%}  owned={is_wm}')"]},

  {"cell_type":"code","execution_count":null,"id":"s5-capstone","metadata":{},"outputs":[],
   "source":["# 5.3  Week 3 Capstone: Privacy-Preserving Active Learning Pipeline\nprint('='*60)\nprint(' WEEK 3 CAPSTONE: PRIVACY-PRESERVING ACTIVE LEARNING')\nprint('='*60)\n\n# Dataset: imbalanced breast cancer\nX_cap, y_cap = load_breast_cancer(return_X_y=True)\nprint(f'Dataset: {X_cap.shape}  Class balance: {y_cap.mean():.2%} positive')\n\n# Step 1: Start with tiny labelled pool\nrng_cap = np.random.default_rng(0)\ninitial_idx  = rng_cap.choice(len(X_cap)-100, 30, replace=False)\ntest_idx     = np.arange(len(X_cap)-100, len(X_cap))\npool_idx     = np.array([i for i in range(len(X_cap)-100)\n                          if i not in set(initial_idx)])\n\nX_test_cap   = X_cap[test_idx];  y_test_cap = y_cap[test_idx]\nscaler_cap   = StandardScaler().fit(X_cap[initial_idx])\n\nlabelled     = list(initial_idx)\nresults_cap  = []\n\nfor al_round in range(12):\n    Xl = scaler_cap.transform(X_cap[labelled])\n    yl = y_cap[labelled]\n    m  = RandomForestClassifier(50, class_weight='balanced', random_state=42).fit(Xl, yl)\n    test_auc = roc_auc_score(y_test_cap, m.predict_proba(scaler_cap.transform(X_test_cap))[:,1])\n    results_cap.append({'round': al_round+1, 'n_labelled': len(labelled), 'auc': round(test_auc,4)})\n\n    # Step 2: Entropy query on unlabelled pool\n    Xu = scaler_cap.transform(X_cap[pool_idx])\n    probs = m.predict_proba(Xu)\n    ent   = -np.sum(probs * np.log(probs + 1e-9), axis=1)\n    query = np.argsort(ent)[::-1][:8]\n\n    # Step 3: DP noise on query probabilities before sharing\n    dp_eps = 2.0\n    dp_probs = np.clip(probs[query] + np.random.laplace(0, 1/dp_eps, probs[query].shape), 0, 1)\n\n    new_idx  = pool_idx[query]\n    labelled = labelled + list(new_idx)\n    pool_idx = np.delete(pool_idx, query)\n\ndf_cap = pd.DataFrame(results_cap)\nprint('\\nPrivacy-Preserving Active Learning Results:')\nprint(df_cap.to_string(index=False))\nprint(f'\\nFinal AUC with {df_cap.n_labelled.iloc[-1]} labels: {df_cap.auc.iloc[-1]:.4f}')"]},

  {"cell_type":"code","execution_count":null,"id":"s5-capstone-viz","metadata":{},"outputs":[],
   "source":["# 5.4  Capstone Visualisation + Full Summary\nfig, axes = plt.subplots(1, 2, figsize=(13, 4))\n\n# AUC learning curve\naxes[0].plot(df_cap['n_labelled'], df_cap['auc'], 'o-', color='#534AB7',\n             linewidth=2, markersize=6)\naxes[0].set_xlabel('Number of labelled samples')\naxes[0].set_ylabel('Test AUC')\naxes[0].set_title('Capstone: Privacy-Preserving Active Learning')\naxes[0].grid(alpha=0.3)\n\n# Round by round annotation\nfor _, row in df_cap.iloc[::3].iterrows():\n    axes[0].annotate(f'{row.auc:.3f}', (row.n_labelled, row.auc),\n                     textcoords='offset points', xytext=(4,4), fontsize=8)\n\n# Watermark verification bar chart\ncases     = ['Watermarked\\nmodel', 'Clean\\nmodel', 'Stolen+\\nretrained']\nrates_wm  = [wm_rate, rate_clean, rate_stolen]\ncolors_wm = ['#1D9E75', '#888780', '#D85A30']\nbars = axes[1].bar(cases, rates_wm, color=colors_wm, alpha=0.85)\naxes[1].axhline(0.90, linestyle='--', color='black', linewidth=1.5, label='Ownership threshold')\naxes[1].set_ylabel('Watermark trigger rate'); axes[1].set_ylim(0, 1.1)\naxes[1].set_title('Model Watermark Ownership Verification')\naxes[1].bar_label(bars, fmt='%.0%', padding=3)\naxes[1].legend()\nplt.tight_layout(); plt.show()"]},

