  {"cell_type":"markdown","id":"s1-md","metadata":{},"source":["---\n","## Session 1 — Federated Learning Simulation\n","**Time:** 9:00–10:30 AM | **Run time: ~10 sec**"]},

  {"cell_type":"code","execution_count":null,"id":"s1-data","metadata":{},"outputs":[],
   "source":["# 1.1  Dataset + IID vs Non-IID Split\nrng = np.random.default_rng(42)\nX_fl, y_fl = make_classification(2000, n_features=12, n_informative=8, random_state=42)\n\n# IID split: round-robin across 5 clients\nN_CLIENTS = 5\niid_clients = [\n    (X_fl[i::N_CLIENTS], y_fl[i::N_CLIENTS])\n    for i in range(N_CLIENTS)\n]\n\n# Non-IID split: each client gets mostly one class\nidx_class0 = np.where(y_fl == 0)[0]\nidx_class1 = np.where(y_fl == 1)[0]\n\nnon_iid_clients = []\nfor i in range(N_CLIENTS):\n    # Clients 0-2: mostly class 0; Clients 3-4: mostly class 1\n    if i < 3:\n        local_idx = np.concatenate([\n            rng.choice(idx_class0, 280, replace=False),\n            rng.choice(idx_class1,  60, replace=False)\n        ])\n    else:\n        local_idx = np.concatenate([\n            rng.choice(idx_class0,  60, replace=False),\n            rng.choice(idx_class1, 280, replace=False)\n        ])\n    rng.shuffle(local_idx)\n    non_iid_clients.append((X_fl[local_idx], y_fl[local_idx]))\n\nprint('IID split — class distribution per client:')\nfor i, (Xc, yc) in enumerate(iid_clients):\n    print(f'  Client {i}: n={len(yc)}  class0={yc.sum()==0} class_balance={yc.mean():.2f}')\nprint('\\nNon-IID split — class distribution per client:')\nfor i, (Xc, yc) in enumerate(non_iid_clients):\n    print(f'  Client {i}: n={len(yc)}  class_balance={yc.mean():.2f}')"]},

  {"cell_type":"code","execution_count":null,"id":"s1-fedavg","metadata":{},"outputs":[],
   "source":["# 1.2  FedAvg Algorithm\ndef initialise_global_model(X_init, y_init):\n    \"\"\"Train on tiny seed data to initialise weights.\"\"\"\n    m = SGDClassifier(loss='log_loss', max_iter=100, random_state=42)\n    m.fit(X_init, y_init)\n    return m.coef_.copy(), m.intercept_.copy()\n\ndef local_train(Xc, yc, coef, intercept, local_epochs=5):\n    \"\"\"Client trains locally starting from global weights.\"\"\"\n    m = SGDClassifier(loss='log_loss', max_iter=local_epochs,\n                      warm_start=True, random_state=42)\n    m.coef_      = coef.copy()\n    m.intercept_ = intercept.copy()\n    m.classes_   = np.array([0, 1])\n    m.fit(Xc, yc)\n    return m.coef_.copy(), m.intercept_.copy()\n\ndef fedavg_aggregate(client_updates, client_sizes):\n    \"\"\"Weighted average of client updates (FedAvg).\"\"\"\n    total = sum(client_sizes)\n    coefs = np.sum([c * s/total for c, s in zip(\n        [u[0] for u in client_updates], client_sizes)], axis=0)\n    ints  = np.sum([i * s/total for i, s in zip(\n        [u[1] for u in client_updates], client_sizes)], axis=0)\n    return coefs, ints\n\ndef evaluate_global(X_test, y_test, coef, intercept):\n    m = SGDClassifier(loss='log_loss', max_iter=1, random_state=42)\n    m.fit(X_test[:10], y_test[:10])  # dummy fit for class info\n    m.coef_      = coef\n    m.intercept_ = intercept\n    m.classes_   = np.array([0, 1])\n    return accuracy_score(y_test, m.predict(X_test))\n\n# Global test set (held-out from all clients)\nX_test_fl  = X_fl[1600:]\ny_test_fl  = y_fl[1600:]\n\n# Run 10 communication rounds for both IID and Non-IID\nglobal_coef, global_int = initialise_global_model(X_fl[:20], y_fl[:20])\niid_accs, non_iid_accs = [], []\n\nfor rnd in range(10):\n    # IID round\n    updates_iid = [local_train(Xc, yc, global_coef, global_int)\n                   for Xc, yc in iid_clients]\n    sizes_iid   = [len(yc) for _, yc in iid_clients]\n    global_coef_iid, global_int_iid = fedavg_aggregate(updates_iid, sizes_iid)\n    iid_accs.append(evaluate_global(X_test_fl, y_test_fl, global_coef_iid, global_int_iid))\n\n    # Non-IID round\n    updates_noniid = [local_train(Xc, yc, global_coef, global_int)\n                      for Xc, yc in non_iid_clients]\n    sizes_noniid   = [len(yc) for _, yc in non_iid_clients]\n    global_coef, global_int = fedavg_aggregate(updates_noniid, sizes_noniid)\n    non_iid_accs.append(evaluate_global(X_test_fl, y_test_fl, global_coef, global_int))\n\nprint('FedAvg Convergence (test accuracy per round):')\nprint(f'{\"Round\":6s} | {\"IID\":8s} | {\"Non-IID\"}')\nfor r, (a, b) in enumerate(zip(iid_accs, non_iid_accs), 1):\n    print(f'{r:6d} | {a:.4f}   | {b:.4f}')\nprint(f'\\nIID final    : {iid_accs[-1]:.4f}')\nprint(f'Non-IID final: {non_iid_accs[-1]:.4f}  (gap = {iid_accs[-1]-non_iid_accs[-1]:.4f})')"]},

  {"cell_type":"code","execution_count":null,"id":"s1-fedavg-plot","metadata":{},"outputs":[],
   "source":["# 1.3  FedAvg Convergence Plot + DP Noise Effect\nfig, axes = plt.subplots(1, 2, figsize=(13, 4))\n\n# Convergence plot\naxes[0].plot(range(1,11), iid_accs,     'o-', color='#534AB7', linewidth=2, label='IID')\naxes[0].plot(range(1,11), non_iid_accs, 's-', color='#D85A30', linewidth=2, label='Non-IID')\naxes[0].set_xlabel('Communication round'); axes[0].set_ylabel('Test accuracy')\naxes[0].set_title('FedAvg: IID vs Non-IID Convergence')\naxes[0].legend(); axes[0].grid(alpha=0.3)\n\n# Client drift visualisation\nclient_final_coefs = []\nfor Xc, yc in non_iid_clients:\n    m = SGDClassifier(loss='log_loss', max_iter=50, random_state=42).fit(Xc, yc)\n    client_final_coefs.append(m.coef_[0])\n\n# Show L2 distance between each client's weights and global\nfor i, cc in enumerate(client_final_coefs):\n    dist = np.linalg.norm(cc - global_coef[0])\n    axes[1].bar(i, dist, color='#534AB7' if i<3 else '#D85A30', alpha=0.85)\naxes[1].set_xlabel('Client index')\naxes[1].set_ylabel('L2 distance from global model')\naxes[1].set_title('Client Drift (Non-IID) — larger = more drift')\nplt.tight_layout(); plt.show()"]},

  {"cell_type":"code","execution_count":null,"id":"s1-dp-fl","metadata":{},"outputs":[],
   "source":["# 1.4  DP-FedAvg: Add Gaussian Noise to Client Updates\ndef dp_local_train(Xc, yc, coef, intercept, noise_sigma=0.01):\n    \"\"\"Client trains locally then adds DP noise before sending update.\"\"\"\n    rng_dp = np.random.default_rng()\n    upd_coef, upd_int = local_train(Xc, yc, coef, intercept)\n    # Clip gradient norm\n    delta_coef = upd_coef - coef\n    clip_norm  = np.linalg.norm(delta_coef)\n    if clip_norm > 1.0:\n        delta_coef /= clip_norm\n    # Add Gaussian noise\n    noisy_coef = coef + delta_coef + rng_dp.normal(0, noise_sigma, coef.shape)\n    noisy_int  = upd_int + rng_dp.normal(0, noise_sigma, upd_int.shape)\n    return noisy_coef, noisy_int\n\n# Run DP-FedAvg\nglobal_coef_dp, global_int_dp = initialise_global_model(X_fl[:20], y_fl[:20])\ndp_accs = []\nfor _ in range(10):\n    updates = [dp_local_train(Xc, yc, global_coef_dp, global_int_dp, noise_sigma=0.05)\n               for Xc, yc in iid_clients]\n    sizes   = [len(yc) for _, yc in iid_clients]\n    global_coef_dp, global_int_dp = fedavg_aggregate(updates, sizes)\n    dp_accs.append(evaluate_global(X_test_fl, y_test_fl, global_coef_dp, global_int_dp))\n\nprint('DP-FedAvg accuracy (σ=0.05):')\nfor r, a in enumerate(dp_accs, 1):\n    print(f'  Round {r}: {a:.4f}')\nprint(f'Final: {dp_accs[-1]:.4f}  (privacy-accuracy trade-off vs standard {iid_accs[-1]:.4f})')"]},

  {"cell_type":"markdown","id":"s2-md","metadata":{},"source":["---\n","## Session 2 — Differential Privacy\n","**Time:** 10:30–11:00 AM | **Run time: ~5 sec**"]},

  {"cell_type":"code","execution_count":null,"id":"s2-laplace","metadata":{},"outputs":[],
   "source":["# 2.1  Laplace & Gaussian Mechanisms\ndef laplace_mechanism(true_val, sensitivity, epsilon):\n    \"\"\"(ε)-DP via Laplace noise.\"\"\"\n    noise = np.random.laplace(0, sensitivity / epsilon)\n    return true_val + noise\n\ndef gaussian_mechanism(true_val, sensitivity, epsilon, delta=1e-5):\n    \"\"\"(ε,δ)-DP via Gaussian noise.\"\"\"\n    sigma = sensitivity * np.sqrt(2 * np.log(1.25 / delta)) / epsilon\n    return true_val + np.random.normal(0, sigma)\n\n# Query: average age in a dataset\nnp.random.seed(42)\nages = np.random.randint(18, 80, 1000)\ntrue_mean = ages.mean()\nSENSITIVITY_MEAN = (80 - 18) / len(ages)   # global sensitivity of mean query\n\nprint(f'True mean age: {true_mean:.4f}')\nprint('\\nLaplace mechanism (ε-DP):')\nfor eps in [0.01, 0.1, 0.5, 1.0, 5.0, 10.0]:\n    np.random.seed(42)\n    dp_vals = [laplace_mechanism(true_mean, SENSITIVITY_MEAN, eps) for _ in range(50)]\n    print(f'  ε={eps:5.2f}: mean={np.mean(dp_vals):7.3f}  std={np.std(dp_vals):.4f}  '\n          f'error={abs(np.mean(dp_vals)-true_mean):.4f}')"]},

  {"cell_type":"code","execution_count":null,"id":"s2-dp-viz","metadata":{},"outputs":[],
   "source":["# 2.2  Privacy-Accuracy Trade-off Visualisation\nepsilons   = [0.05, 0.1, 0.2, 0.5, 1.0, 2.0, 5.0, 10.0]\nmean_errors = []\nstd_errors  = []\n\nfor eps in epsilons:\n    np.random.seed(7)\n    vals = [laplace_mechanism(true_mean, SENSITIVITY_MEAN, eps) for _ in range(200)]\n    mean_errors.append(np.mean(np.abs(np.array(vals) - true_mean)))\n    std_errors.append(np.std(vals))\n\nfig, axes = plt.subplots(1, 2, figsize=(13, 4))\n\naxes[0].semilogx(epsilons, mean_errors, 'o-', color='#534AB7', linewidth=2)\naxes[0].set_xlabel('Privacy budget ε (log scale)')\naxes[0].set_ylabel('Mean absolute error')\naxes[0].set_title('Privacy-Accuracy Trade-off\\n(lower ε = stronger privacy = more error)')\naxes[0].grid(alpha=0.3)\n\n# Show noise distributions for different ε\nxs = np.linspace(-5, 5, 300)\nfor eps, color in [(0.1,'#D85A30'), (1.0,'#534AB7'), (5.0,'#1D9E75')]:\n    scale = SENSITIVITY_MEAN / eps\n    dens  = np.exp(-np.abs(xs) / scale) / (2 * scale)\n    axes[1].plot(xs, dens, linewidth=2, color=color, label=f'ε={eps}')\naxes[1].set_title('Laplace Noise Distribution')\naxes[1].set_xlabel('Noise value'); axes[1].set_ylabel('Density')\naxes[1].legend(); axes[1].grid(alpha=0.3)\nplt.tight_layout(); plt.show()"]},

  {"cell_type":"code","execution_count":null,"id":"s2-dp-classifier","metadata":{},"outputs":[],
   "source":["# 2.3  DP Applied to Model Predictions (Output Perturbation)\nX_dp, y_dp = load_breast_cancer(return_X_y=True)\nX_tr_dp, X_te_dp, y_tr_dp, y_te_dp = train_test_split(X_dp, y_dp, test_size=0.2, random_state=42)\n\nscaler_dp = StandardScaler().fit(X_tr_dp)\nmodel_dp  = LogisticRegression(max_iter=500).fit(scaler_dp.transform(X_tr_dp), y_tr_dp)\n\n# True predictions\ntrue_preds = model_dp.predict_proba(scaler_dp.transform(X_te_dp))[:, 1]\ntrue_acc   = accuracy_score(y_te_dp, (true_preds >= 0.5).astype(int))\n\n# DP predictions: add Laplace noise to output probabilities\nprint('Output perturbation DP:')\nfor eps in [0.1, 0.5, 1.0, 5.0]:\n    np.random.seed(42)\n    dp_preds = np.clip(true_preds + np.random.laplace(0, 1/eps, len(true_preds)), 0, 1)\n    dp_acc   = accuracy_score(y_te_dp, (dp_preds >= 0.5).astype(int))\n    print(f'  ε={eps:.1f}: accuracy={dp_acc:.4f}  (drop={true_acc-dp_acc:.4f})')\nprint(f'  No DP: accuracy={true_acc:.4f}')"]},

  {"cell_type":"markdown","id":"s3-md","metadata":{},"source":["---\n","## Session 3 — Active Learning: Query Strategies\n","**Time:** 11:00 AM–1:00 PM | **Run time: ~20 sec**"]},

  {"cell_type":"code","execution_count":null,"id":"s3-strategies","metadata":{},"outputs":[],
   "source":["# 3.1  Active Learning Query Strategies\nX_al, y_al = make_classification(1200, n_features=12, n_informative=8,\n                                  random_state=42, weights=[0.6, 0.4])\n\n# Fixed test set\nX_test_al  = X_al[1000:]\ny_test_al  = y_al[1000:]\nX_pool     = X_al[:1000]\ny_pool     = y_al[:1000]\n\ndef uncertainty_sampling(model, X_pool, n_query=10):\n    \"\"\"Pick samples with smallest max class probability.\"\"\"\n    probs = model.predict_proba(X_pool)\n    uncertainty = 1 - probs.max(axis=1)\n    return np.argsort(uncertainty)[::-1][:n_query]\n\ndef margin_sampling(model, X_pool, n_query=10):\n    \"\"\"Pick samples with smallest margin between top-2 probs.\"\"\"\n    probs  = model.predict_proba(X_pool)\n    sorted_p = np.sort(probs, axis=1)[:, ::-1]\n    margin = sorted_p[:, 0] - sorted_p[:, 1]\n    return np.argsort(margin)[:n_query]\n\ndef entropy_sampling(model, X_pool, n_query=10):\n    \"\"\"Pick samples with highest prediction entropy.\"\"\"\n    probs   = model.predict_proba(X_pool)\n    entropy = -np.sum(probs * np.log(probs + 1e-9), axis=1)\n    return np.argsort(entropy)[::-1][:n_query]\n\ndef random_sampling(model, X_pool, n_query=10):\n    \"\"\"Random baseline — no strategy.\"\"\"\n    return np.random.choice(len(X_pool), n_query, replace=False)\n\nprint('Query strategies implemented:')\nfor name in ['Uncertainty', 'Margin', 'Entropy', 'Random']:\n    print(f'  - {name} sampling')"]},

  {"cell_type":"code","execution_count":null,"id":"s3-simulation","metadata":{},"outputs":[],
   "source":["# 3.2  Simulate Active Learning Loop\ndef run_active_learning(query_fn, n_initial=20, n_query=10, n_rounds=15, seed=42):\n    np.random.seed(seed)\n    # Start with small labelled pool\n    labelled_idx   = np.random.choice(len(X_pool), n_initial, replace=False)\n    unlabelled_idx = np.array([i for i in range(len(X_pool)) if i not in set(labelled_idx)])\n    accuracies     = []\n\n    for _ in range(n_rounds):\n        # Train on current labelled set\n        model = RandomForestClassifier(40, random_state=42)\n        model.fit(X_pool[labelled_idx], y_pool[labelled_idx])\n        acc   = model.score(X_test_al, y_test_al)\n        accuracies.append((len(labelled_idx), acc))\n\n        if len(unlabelled_idx) < n_query:\n            break\n        # Query most informative samples\n        query_idx      = query_fn(model, X_pool[unlabelled_idx], n_query)\n        new_labels     = unlabelled_idx[query_idx]\n        labelled_idx   = np.concatenate([labelled_idx, new_labels])\n        unlabelled_idx = np.delete(unlabelled_idx, query_idx)\n\n    return accuracies\n\n# Run all strategies\nstrategies = {\n    'Uncertainty': uncertainty_sampling,\n    'Margin'     : margin_sampling,\n    'Entropy'    : entropy_sampling,\n    'Random'     : random_sampling,\n}\nresults_al = {}\nfor name, fn in strategies.items():\n    results_al[name] = run_active_learning(fn)\n    final_n, final_acc = results_al[name][-1]\n    print(f'{name:12s}: final_acc={final_acc:.4f}  n_labelled={final_n}')"]},

  {"cell_type":"code","execution_count":null,"id":"s3-plot","metadata":{},"outputs":[],
   "source":["# 3.3  Learning Curve Comparison\nfig, ax = plt.subplots(figsize=(10, 5))\ncolors_al = {'Uncertainty':'#534AB7','Margin':'#1D9E75','Entropy':'#D85A30','Random':'#888780'}\n\nfor name, results in results_al.items():\n    sizes = [r[0] for r in results]\n    accs  = [r[1] for r in results]\n    lw    = 2.5 if name != 'Random' else 1.5\n    ls    = '-'  if name != 'Random' else '--'\n    ax.plot(sizes, accs, marker='o', markersize=5, linewidth=lw, linestyle=ls,\n            color=colors_al[name], label=name)\n\nax.set_xlabel('Number of labelled samples')\nax.set_ylabel('Test accuracy')\nax.set_title('Active Learning: Label Efficiency Comparison')\nax.legend(); ax.grid(alpha=0.3)\nplt.tight_layout(); plt.show()\n\n# Compute label efficiency: samples needed to reach 85% accuracy\nprint('\\nLabel efficiency (samples to reach 85% accuracy):')\nfor name, results in results_al.items():\n    for n, acc in results:\n        if acc >= 0.85:\n            print(f'  {name:12s}: {n} samples')\n            break\n    else:\n        print(f'  {name:12s}: did not reach 85%')"]},

  {"cell_type":"code","execution_count":null,"id":"s3-qbc","metadata":{},"outputs":[],
   "source":["# 3.4  Query by Committee (QBC)\nclass QueryByCommittee:\n    \"\"\"Ensemble of models — query where they disagree most.\"\"\"\n    def __init__(self, n_members=5):\n        self.committee = [\n            RandomForestClassifier(30, random_state=i).fit\n            for i in range(n_members)\n        ]\n        self.n = n_members\n\n    def fit(self, X, y):\n        self.models = [RandomForestClassifier(30, random_state=i).fit(X, y)\n                       for i in range(self.n)]\n        return self\n\n    def predict_proba(self, X):\n        return np.mean([m.predict_proba(X) for m in self.models], axis=0)\n\n    def disagreement(self, X):\n        \"\"\"Vote entropy: how much committee members disagree.\"\"\"\n        votes = np.array([m.predict(X) for m in self.models])\n        # Disagreement = fraction of minority votes\n        return np.array([1 - max(np.bincount(votes[:, i], minlength=2)) / self.n\n                         for i in range(X.shape[0])])\n\nqbc = QueryByCommittee(n_members=5)\nqbc.fit(X_pool[:100], y_pool[:100])\ndisagreement = qbc.disagreement(X_pool[100:200])\nprint(f'QBC: mean disagreement={disagreement.mean():.4f}')\nprint(f'Top-5 most contested samples: {np.argsort(disagreement)[::-1][:5] + 100}')"]},

  {"cell_type":"markdown","id":"lunch-md","metadata":{},"source":["---\n","## Lunch Break — 1:00–2:00 PM\n","1. Why does non-IID data cause client drift in FedAvg?\n","2. What does ε=0.1 versus ε=10 mean for a user's privacy?\n","3. Why is entropy sampling better than random when labels are expensive?\n","4. How does backdoor watermarking detect stolen models?\n","---"]},

