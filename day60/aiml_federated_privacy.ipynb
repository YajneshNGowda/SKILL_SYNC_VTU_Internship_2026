   "source":["# Bonus: Day 12 in one cell\nX_b, y_b = make_classification(500, n_features=8, random_state=42)\n\n# Quick FedAvg\nm_init = SGDClassifier(loss='log_loss', random_state=42).fit(X_b[:20], y_b[:20])\nclients_b = [(X_b[i::4], y_b[i::4]) for i in range(4)]\nall_coefs = [local_train(Xc, yc, m_init.coef_, m_init.intercept_)\n             for Xc, yc in clients_b]\nglobal_c, global_i = fedavg_aggregate(all_coefs, [len(yc) for _,yc in clients_b])\nprint(f'FedAvg converged: coef norm={np.linalg.norm(global_c):.4f}')\n\n# Quick DP\nnp.random.seed(0)\ndp_val = laplace_mechanism(48.93, 0.062, epsilon=1.0)\nprint(f'DP mean query (ε=1.0): {dp_val:.3f}  (true=48.93)')\n\n# Quick active learning\nm_al = RandomForestClassifier(20, random_state=42).fit(X_b[:50], y_b[:50])\nent  = -np.sum(m_al.predict_proba(X_b[50:100]) * np.log(m_al.predict_proba(X_b[50:100])+1e-9), axis=1)\nprint(f'Top uncertain sample index: {50 + ent.argmax()} (entropy={ent.max():.4f})')\n\nprint('\\nDay 12 & Week 3 complete — federated, private, active, watermarked ML!')"]},
