   "source":["# 🕸️ Day 8 — Graph ML, VAE Anomaly, Fraud & CI/CD\n","**Duration:** 6 Hours | **Total run time: under 60 seconds**\n\n","| Session | Time | Topic | Run Time |\n","|---------|------|-------|----------|\n","| 1 | 9:00–10:30 AM | Graph ML with NetworkX | ~8 sec |\n","| 2 | 10:30–11:00 AM | Autoencoder Anomaly Detection | ~5 sec |\n","| 3 | 11:00 AM–1:00 PM | End-to-End Fraud Detection | ~20 sec |\n","| 4 | 1:00–2:00 PM | Lunch Break | — |\n","| 5 | 2:00–4:00 PM | ML CI/CD Retraining Pipeline | ~15 sec |\n\n","> **Zero downloads. Pure numpy + sklearn + networkx.**\n","---"]},

  {"cell_type":"code","execution_count":null,"id":"setup","metadata":{},"outputs":[],
   "source":["# !pip install scikit-learn networkx matplotlib pandas numpy scipy\n","import numpy as np\n","import pandas as pd\n","import matplotlib.pyplot as plt\n","from scipy import stats\n","import hashlib, json, warnings\n","from datetime import datetime\n","warnings.filterwarnings('ignore')\n","import networkx as nx\n","from sklearn.ensemble import RandomForestClassifier, IsolationForest, GradientBoostingClassifier\n","from sklearn.linear_model import LogisticRegression\n","from sklearn.model_selection import train_test_split, cross_val_score\n","from sklearn.preprocessing import StandardScaler\n","from sklearn.pipeline import make_pipeline\n","from sklearn.metrics import (\n","    accuracy_score, roc_auc_score, classification_report,\n","    average_precision_score, precision_recall_curve, roc_curve\n",")\n","import sklearn\n","print('All imports OK')\n","print(f'   sklearn   : {sklearn.__version__}')\n","print(f'   networkx  : {nx.__version__}')"]},

  {"cell_type":"markdown","id":"s1-md","metadata":{},
   "source":["---\n","## Session 1 — Graph ML with NetworkX\n","**Time:** 9:00–10:30 AM | **Run time: ~8 sec**"]},

  {"cell_type":"code","execution_count":null,"id":"s1-graph","metadata":{},"outputs":[],
   "source":["# 1.1  Load Karate Club Graph\n","G = nx.karate_club_graph()\n","print(f'Nodes: {G.number_of_nodes()}  Edges: {G.number_of_edges()}')\n","print(f'Density: {nx.density(G):.4f}')\n","print(f'Average degree: {sum(d for _,d in G.degree())/G.number_of_nodes():.2f}')\n","# Ground truth: which club does each member belong to?\n","labels_gt = np.array([1 if G.nodes[n]['club']=='Mr. Hi' else 0 for n in G.nodes()])\n","print(f'Class balance: {labels_gt.sum()} Mr.Hi vs {(1-labels_gt).sum()} Officer')"]},

  {"cell_type":"code","execution_count":null,"id":"s1-centrality","metadata":{},"outputs":[],
   "source":["# 1.2  Extract Graph Features (Centrality Measures)\n","nodes = list(G.nodes())\n","degree_c   = nx.degree_centrality(G)\n","between_c  = nx.betweenness_centrality(G)\n","close_c    = nx.closeness_centrality(G)\n","pagerank   = nx.pagerank(G, alpha=0.85)\n","clustering  = nx.clustering(G)\n","eigenvec_c = nx.eigenvector_centrality(G, max_iter=1000)\n","\n","feature_matrix = np.array([\n","    [degree_c[n], between_c[n], close_c[n],\n","     pagerank[n], clustering[n], eigenvec_c[n],\n","     G.degree(n)]          # raw degree count\n","    for n in nodes\n","])\n","\n","feat_names = ['degree_c','betweenness','closeness','pagerank','clustering','eigenvec','degree']\n","feat_df = pd.DataFrame(feature_matrix, index=nodes, columns=feat_names)\n","feat_df['label'] = labels_gt\n","print('Feature matrix shape:', feature_matrix.shape)\n","print(feat_df.round(4).head())"]},

  {"cell_type":"code","execution_count":null,"id":"s1-classify","metadata":{},"outputs":[],
   "source":["# 1.3  Classify Nodes Using Graph Features\n","from sklearn.model_selection import LeaveOneOut\n","\n","X_g, y_g = feature_matrix, labels_gt\n","# LOO CV because dataset is tiny (34 nodes)\n","loo = LeaveOneOut()\n","rf_g = RandomForestClassifier(50, random_state=42)\n","loo_preds = []\n","for tr_idx, te_idx in loo.split(X_g):\n","    rf_g.fit(X_g[tr_idx], y_g[tr_idx])\n","    loo_preds.append(rf_g.predict(X_g[te_idx])[0])\n","\n","loo_acc = accuracy_score(y_g, loo_preds)\n","print(f'LOO-CV accuracy (graph features): {loo_acc:.4f}')\n","\n","# Feature importance\n","rf_g.fit(X_g, y_g)\n","imp_g = pd.DataFrame({'feature': feat_names, 'importance': rf_g.feature_importances_})\\\n","          .sort_values('importance', ascending=True)\n","\n","fig, axes = plt.subplots(1, 2, figsize=(13, 4))\n","axes[0].barh(imp_g['feature'], imp_g['importance'], color='#534AB7', alpha=0.85)\n","axes[0].set_title('Graph Feature Importance')\n","axes[0].set_xlabel('Importance')\n","\n","# Visualise the graph\n","pos = nx.spring_layout(G, seed=42)\n","colors = ['#534AB7' if l==1 else '#D85A30' for l in labels_gt]\n","nx.draw_networkx(G, pos, node_color=colors, node_size=200,\n","                 font_size=7, ax=axes[1], edge_color='gray', alpha=0.8)\n","axes[1].set_title('Karate Club Graph (blue=Mr.Hi, red=Officer)')\n","axes[1].axis('off')\n","plt.tight_layout(); plt.show()"]},

  {"cell_type":"code","execution_count":null,"id":"s1-community","metadata":{},"outputs":[],
   "source":["# 1.4  Community Detection\n","from networkx.algorithms.community import greedy_modularity_communities\n","\n","communities = list(greedy_modularity_communities(G))\n","print(f'Communities found: {len(communities)}')\n","for i, c in enumerate(communities):\n","    print(f'  Community {i+1}: {sorted(c)}')\n","\n","# Assign community labels and check overlap with ground truth\n","community_map = {}\n","for i, c in enumerate(communities):\n","    for node in c:\n","        community_map[node] = i\n","community_labels = np.array([community_map[n] for n in nodes])\n","from sklearn.metrics import adjusted_rand_score\n","ari = adjusted_rand_score(labels_gt, community_labels)\n","print(f'\\nAdjusted Rand Index vs ground truth: {ari:.4f}  (1.0 = perfect)')"]},

  {"cell_type":"markdown","id":"s2-md","metadata":{},"source":["---\n","## Session 2 — Autoencoder Anomaly Detection\n","**Time:** 10:30–11:00 AM | **Run time: ~5 sec**"]},

  {"cell_type":"code","execution_count":null,"id":"s2-ae","metadata":{},"outputs":[],
   "source":["# 2.1  Numpy Autoencoder (no PyTorch needed)\n","np.random.seed(42)\n","N_normal, N_anom = 600, 30\n","X_normal = np.random.normal(0, 1, (N_normal, 10))\n","X_anom   = np.random.normal(4, 1.5, (N_anom, 10))  # shifted distribution\n","X_all    = np.vstack([X_normal, X_anom])\n","y_all    = np.array([0]*N_normal + [1]*N_anom)\n","\n","# Encoder: 10 → 4 (bottleneck)\n","# Decoder: 4 → 10\n","W_enc = np.random.randn(10, 4) * 0.1\n","W_dec = np.random.randn(4, 10) * 0.1\n","LR_AE, EPOCHS_AE = 0.02, 500\n","\n","ae_losses = []\n","for epoch in range(EPOCHS_AE):\n","    # Forward\n","    h     = np.tanh(X_normal @ W_enc)          # encoded\n","    recon = h @ W_dec                           # reconstructed\n","    loss  = np.mean((recon - X_normal)**2)\n","    ae_losses.append(loss)\n","    # Backward\n","    dL_dr  = 2 * (recon - X_normal) / N_normal\n","    dW_dec = h.T @ dL_dr\n","    dL_dh  = dL_dr @ W_dec.T * (1 - h**2)      # tanh grad\n","    dW_enc = X_normal.T @ dL_dh\n","    W_enc -= LR_AE * dW_enc\n","    W_dec -= LR_AE * dW_dec\n","\n","print(f'Final AE loss: {ae_losses[-1]:.6f}')"]},

  {"cell_type":"code","execution_count":null,"id":"s2-anomaly-score","metadata":{},"outputs":[],
   "source":["# 2.2  Reconstruction Error as Anomaly Score\n","def reconstruct_error(X, W_enc, W_dec):\n","    h = np.tanh(X @ W_enc)\n","    recon = h @ W_dec\n","    return np.mean((recon - X)**2, axis=1)\n","\n","errors = reconstruct_error(X_all, W_enc, W_dec)\n","threshold_95 = np.percentile(errors[:N_normal], 95)\n","preds_ae = (errors > threshold_95).astype(int)\n","\n","auc_ae = roc_auc_score(y_all, errors)\n","ap_ae  = average_precision_score(y_all, errors)\n","print(f'Autoencoder anomaly detection:')\n","print(f'  AUC              : {auc_ae:.4f}')\n","print(f'  Avg Precision    : {ap_ae:.4f}')\n","print(f'  Threshold (p95)  : {threshold_95:.4f}')\n","print(f'  Flagged anomalies: {preds_ae.sum()}  (true: {N_anom})')\n","\n","# Compare with IsolationForest\n","iso = IsolationForest(contamination=N_anom/(N_normal+N_anom), random_state=42)\n","iso_scores = -iso.fit(X_normal).score_samples(X_all)\n","auc_iso = roc_auc_score(y_all, iso_scores)\n","print(f'\\nIsolationForest AUC: {auc_iso:.4f}')"]},

  {"cell_type":"code","execution_count":null,"id":"s2-ae-viz","metadata":{},"outputs":[],
   "source":["# 2.3  Visualise Reconstruction Error Distribution\n","fig, axes = plt.subplots(1, 2, figsize=(13, 4))\n","\n","axes[0].hist(errors[:N_normal], bins=30, color='#534AB7', alpha=0.7, label='Normal', density=True)\n","axes[0].hist(errors[N_normal:], bins=15, color='#D85A30', alpha=0.7, label='Anomaly', density=True)\n","axes[0].axvline(threshold_95, color='black', linestyle='--', linewidth=2, label=f'Threshold={threshold_95:.3f}')\n","axes[0].set_xlabel('Reconstruction Error'); axes[0].set_ylabel('Density')\n","axes[0].set_title('Autoencoder: Reconstruction Error')\n","axes[0].legend()\n","\n","fpr_ae, tpr_ae, _ = roc_curve(y_all, errors)\n","fpr_iso, tpr_iso, _ = roc_curve(y_all, iso_scores)\n","axes[1].plot(fpr_ae, tpr_ae, color='#534AB7', linewidth=2, label=f'Autoencoder (AUC={auc_ae:.3f})')\n","axes[1].plot(fpr_iso, tpr_iso, color='#1D9E75', linewidth=2, label=f'IsoForest (AUC={auc_iso:.3f})')\n","axes[1].plot([0,1],[0,1],'k--',alpha=0.4)\n","axes[1].set_xlabel('FPR'); axes[1].set_ylabel('TPR')\n","axes[1].set_title('ROC: Autoencoder vs IsolationForest')\n","axes[1].legend()\n","plt.tight_layout(); plt.show()"]},

  {"cell_type":"markdown","id":"s3-md","metadata":{},"source":["---\n","## Session 3 — End-to-End Fraud Detection System\n","**Time:** 11:00 AM–1:00 PM | **Run time: ~20 sec**"]},

  {"cell_type":"code","execution_count":null,"id":"s3-fraud-data","metadata":{},"outputs":[],
   "source":["# 3.1  Generate Synthetic Transaction Dataset\n","rng = np.random.default_rng(0)\n","N   = 5000\n","\n","df_tx = pd.DataFrame({\n","    'amount'      : rng.exponential(500, N).round(2),\n","    'hour'        : rng.integers(0, 24, N),\n","    'day_of_week' : rng.integers(0, 7, N),\n","    'velocity_1h' : rng.integers(1, 30, N),    # txns in last hour\n","    'velocity_24h': rng.integers(1, 80, N),    # txns in last 24h\n","    'foreign'     : rng.choice([0,1], N, p=[0.90, 0.10]),\n","    'new_device'  : rng.choice([0,1], N, p=[0.85, 0.15]),\n","    'card_age_days': rng.integers(1, 2000, N),\n","    'merchant_risk': rng.uniform(0, 1, N).round(3),\n","    'user_id'     : rng.integers(0, 500, N),\n","})\n","\n","# Realistic fraud probability\n","fraud_logit = (\n","    0.003 * df_tx['amount']\n","    + 0.15  * df_tx['foreign']\n","    + 0.12  * df_tx['new_device']\n","    + 0.04  * df_tx['velocity_1h']\n","    + 0.008 * df_tx['velocity_24h']\n","    + 0.30  * df_tx['merchant_risk']\n","    - 0.0003* df_tx['card_age_days']\n","    + (df_tx['hour'] < 5).astype(float) * 0.20   # late-night bonus\n","    + rng.normal(0, 0.4, N)\n","    - 3.5\n",")\n","fraud_prob = 1 / (1 + np.exp(-fraud_logit))\n","df_tx['fraud'] = (rng.random(N) < fraud_prob).astype(int)\n","\n","print(f'Transactions : {N}')\n","print(f'Fraud rate   : {df_tx.fraud.mean():.2%} ({df_tx.fraud.sum()} cases)')\n","print(f'Avg amount   : {df_tx.amount.mean():.2f}')"]},

  {"cell_type":"code","execution_count":null,"id":"s3-rules","metadata":{},"outputs":[],
   "source":["# 3.2  Rule-Based Pre-Filter (Fast Hard Rules)\n","def apply_rules(df):\n","    flags = pd.Series(False, index=df.index)\n","    # Rule 1: Very high amount + foreign\n","    flags |= (df['amount'] > 2000) & (df['foreign'] == 1)\n","    # Rule 2: High velocity + new device\n","    flags |= (df['velocity_1h'] > 20) & (df['new_device'] == 1)\n","    # Rule 3: Late night + high merchant risk\n","    flags |= (df['hour'] < 5) & (df['merchant_risk'] > 0.8)\n","    # Rule 4: Extremely high velocity\n","    flags |= df['velocity_1h'] > 25\n","    return flags.astype(int)\n","\n","df_tx['rule_flag'] = apply_rules(df_tx)\n","rule_precision = df_tx[df_tx['rule_flag']==1]['fraud'].mean()\n","rule_recall    = df_tx[df_tx['rule_flag']==1]['fraud'].sum() / df_tx['fraud'].sum()\n","\n","print('Rule Engine Results:')\n","print(f'  Flagged        : {df_tx.rule_flag.sum()} transactions')\n","print(f'  Rule precision : {rule_precision:.3f}')\n","print(f'  Rule recall    : {rule_recall:.3f}')"]},

  {"cell_type":"code","execution_count":null,"id":"s3-ml-layer","metadata":{},"outputs":[],
   "source":["# 3.3  ML Second Layer on Rule-Passed Transactions\n","# Feature engineering\n","df_ml = df_tx.copy()\n","df_ml['amount_log']          = np.log1p(df_ml['amount'])\n","df_ml['velocity_ratio']      = df_ml['velocity_1h'] / (df_ml['velocity_24h'] + 1)\n","df_ml['high_risk_late_night']= ((df_ml['hour'] < 5) & (df_ml['merchant_risk'] > 0.6)).astype(int)\n","df_ml['amount_x_foreign']    = df_ml['amount_log'] * df_ml['foreign']\n","df_ml['card_age_bin']        = pd.cut(df_ml['card_age_days'],\n","                                       bins=[0,30,180,365,2000],\n","                                       labels=[0,1,2,3]).astype(int)\n","\n","FEATS = ['amount_log','hour','velocity_1h','velocity_24h','foreign',\n","         'new_device','card_age_days','merchant_risk','velocity_ratio',\n","         'high_risk_late_night','amount_x_foreign','card_age_bin']\n","\n","X_fr = df_ml[FEATS].values\n","y_fr = df_ml['fraud'].values\n","\n","X_tr, X_te, y_tr, y_te = train_test_split(X_fr, y_fr, test_size=0.2,\n","                                            random_state=42, stratify=y_fr)\n","fraud_models = {\n","    'LogReg'         : make_pipeline(StandardScaler(), LogisticRegression(max_iter=500)),\n","    'RandomForest'   : RandomForestClassifier(100, class_weight='balanced', random_state=42),\n","    'GradBoost'      : GradientBoostingClassifier(80, learning_rate=0.1, random_state=42),\n","}\n","print('Fraud Model Leaderboard:')\n","trained_fraud = {}\n","for name, model in fraud_models.items():\n","    model.fit(X_tr, y_tr)\n","    prob = model.predict_proba(X_te)[:,1]\n","    auc  = roc_auc_score(y_te, prob)\n","    ap   = average_precision_score(y_te, prob)\n","    trained_fraud[name] = (model, prob)\n","    print(f'  {name:15s}: AUC={auc:.4f}  AP={ap:.4f}')"]},

  {"cell_type":"code","execution_count":null,"id":"s3-alert","metadata":{},"outputs":[],
   "source":["# 3.4  Alert Prioritisation\n","best_fraud_model = trained_fraud['RandomForest'][0]\n","all_probs        = best_fraud_model.predict_proba(X_fr)[:,1]\n","df_ml['fraud_prob'] = all_probs\n","\n","# Priority score = fraud_prob × sqrt(amount) — prioritise high-value fraud\n","df_ml['priority'] = df_ml['fraud_prob'] * np.sqrt(df_ml['amount'])\n","top_alerts = df_ml[df_ml['fraud_prob'] > 0.6].sort_values('priority', ascending=False).head(20)\n","\n","print('Top 10 High-Priority Fraud Alerts:')\n","print(top_alerts[['amount','hour','foreign','new_device','merchant_risk',\n","                   'fraud_prob','priority','fraud']].head(10).round(3).to_string(index=False))\n","\n","# Business metric\n","flagged = df_ml[df_ml['fraud_prob'] > 0.5]\n","true_pos = flagged['fraud'].sum()\n","total_fraud_amount = df_ml[df_ml['fraud']==1]['amount'].sum()\n","caught_amount      = flagged[flagged['fraud']==1]['amount'].sum()\n","print(f'\\nFraud amount caught : {caught_amount/total_fraud_amount:.1%} of total fraud value')"]},

  {"cell_type":"code","execution_count":null,"id":"s3-viz","metadata":{},"outputs":[],
   "source":["# 3.5  Fraud System Visualisation\n","best_prob = trained_fraud['RandomForest'][1]\n","fig, axes = plt.subplots(1, 3, figsize=(15, 4))\n","\n","# Score distribution\n","axes[0].hist(best_prob[y_te==0], bins=30, alpha=0.6, color='#534AB7', label='Legit', density=True)\n","axes[0].hist(best_prob[y_te==1], bins=20, alpha=0.7, color='#D85A30', label='Fraud', density=True)\n","axes[0].set_title('Fraud Score Distribution'); axes[0].set_xlabel('Fraud probability')\n","axes[0].legend()\n","\n","# ROC curves\n","for (name, (_, prob)), color in zip(trained_fraud.items(), ['#534AB7','#1D9E75','#D85A30']):\n","    fpr_,tpr_,_=roc_curve(y_te,prob)\n","    auc_=roc_auc_score(y_te,prob)\n","    axes[1].plot(fpr_,tpr_,color=color,linewidth=1.8,label=f'{name} ({auc_:.3f})')\n","axes[1].plot([0,1],[0,1],'k--',alpha=0.4)\n","axes[1].set_title('ROC Curves'); axes[1].set_xlabel('FPR'); axes[1].set_ylabel('TPR')\n","axes[1].legend(fontsize=8)\n","\n","# Fraud rate by hour\n","hr_fraud = df_tx.groupby('hour')['fraud'].mean()\n","axes[2].bar(hr_fraud.index, hr_fraud.values, color='#854F0B', alpha=0.85)\n","axes[2].set_title('Fraud Rate by Hour of Day'); axes[2].set_xlabel('Hour')\n","axes[2].set_ylabel('Fraud rate')\n","plt.tight_layout(); plt.show()"]},

  {"cell_type":"markdown","id":"lunch-md","metadata":{},"source":["---\n","## Lunch Break — 1:00–2:00 PM\n","1. How does betweenness centrality differ from degree centrality?\n","2. Why does reconstruction error flag anomalies?\n","3. What makes fraud detection harder than churn prediction?\n","4. Why use champion-challenger before deploying a new model?\n","---"]},

  {"cell_type":"markdown","id":"s5-md","metadata":{},"source":["## Session 5 — ML CI/CD: Automated Retraining Pipeline\n","**Time:** 2:00–4:00 PM | **Run time: ~15 sec**"]},

  {"cell_type":"code","execution_count":null,"id":"s5-registry","metadata":{},"outputs":[],
   "source":["# 5.1  Model Registry\n","class ModelRegistry:\n","    def __init__(self):\n","        self.models = {}\n","\n","    def register(self, name, model, metrics, data_hash, notes=''):\n","        versions = [k for k in self.models if k.startswith(name)]\n","        v_num    = len(versions) + 1\n","        key      = f'{name}_v{v_num}'\n","        self.models[key] = {\n","            'model'      : model,\n","            'metrics'    : metrics,\n","            'data_hash'  : data_hash,\n","            'timestamp'  : datetime.utcnow().isoformat(),\n","            'notes'      : notes,\n","            'status'     : 'challenger',\n","        }\n","        return key\n","\n","    def promote(self, key):\n","        name = key.rsplit('_v', 1)[0]\n","        for k in self.models:\n","            if k.startswith(name):\n","                self.models[k]['status'] = 'retired'\n","        self.models[key]['status'] = 'champion'\n","\n","    def champion(self, name):\n","        candidates = {k:v for k,v in self.models.items()\n","                      if k.startswith(name) and v['status'] == 'champion'}\n","        return max(candidates, key=lambda k: candidates[k]['metrics']['auc']) if candidates else None\n","\n","    def summary(self):\n","        rows = []\n","        for k, v in self.models.items():\n","            rows.append({'version': k, 'auc': v['metrics']['auc'],\n","                         'status': v['status'], 'timestamp': v['timestamp'][:19]})\n","        return pd.DataFrame(rows)\n","\n","registry = ModelRegistry()\n","print('Model registry created')"]},

  {"cell_type":"code","execution_count":null,"id":"s5-data-hash","metadata":{},"outputs":[],
   "source":["# 5.2  Data Versioning with Hashing\n","def hash_dataset(X, y):\n","    \"\"\"Stable hash of a dataset to detect changes.\"\"\"\n","    combined = np.hstack([X, y.reshape(-1,1)])\n","    return hashlib.md5(combined.tobytes()).hexdigest()[:12]\n","\n","# Simulate two versions of training data\n","rng = np.random.default_rng(1)\n","X_v1, y_v1 = X_tr.copy(), y_tr.copy()\n","# Version 2: new month of data arrives\n","X_new = rng.normal(0, 1, (200, X_tr.shape[1]))\n","y_new = rng.integers(0, 2, 200)\n","X_v2  = np.vstack([X_v1, X_new])\n","y_v2  = np.concatenate([y_v1, y_new])\n","\n","h1 = hash_dataset(X_v1, y_v1)\n","h2 = hash_dataset(X_v2, y_v2)\n","print(f'Dataset v1 hash: {h1}')\n","print(f'Dataset v2 hash: {h2}')\n","print(f'Data changed   : {h1 != h2}  → trigger retraining check')"]},

  {"cell_type":"code","execution_count":null,"id":"s5-psi-trigger","metadata":{},"outputs":[],
   "source":["# 5.3  Drift-Triggered Retraining Decision\n","def compute_psi(expected, actual, n_bins=8):\n","    breaks = np.unique(np.percentile(expected, np.linspace(0, 100, n_bins+1)))\n","    e = np.histogram(expected, bins=breaks)[0] / len(expected) + 1e-8\n","    a = np.histogram(actual,   bins=breaks)[0] / len(actual)   + 1e-8\n","    return float(np.sum((a - e) * np.log(a / e)))\n","\n","# Simulate production scores over 6 months\n","rng = np.random.default_rng(7)\n","base_scores = rng.beta(2, 8, 1000)   # train score distribution\n","\n","print('Monthly PSI Monitoring:')\n","print(f'{\"Month\":8s} | {\"PSI\":6s} | {\"Decision\"}')\n","print('-' * 40)\n","RETRAIN_THRESHOLD = 0.15\n","for month in range(1, 7):\n","    drift = month * 0.04\n","    prod_scores = rng.beta(max(0.5, 2-drift), max(3, 8+drift*2), 500)\n","    psi_val     = compute_psi(base_scores, prod_scores)\n","    decision    = 'RETRAIN' if psi_val > RETRAIN_THRESHOLD else 'Monitor'\n","    print(f'Month {month:<3} | {psi_val:.4f} | {decision}')"]},

  {"cell_type":"code","execution_count":null,"id":"s5-champion-challenger","metadata":{},"outputs":[],
   "source":["# 5.4  Champion-Challenger Retraining\n","def train_and_evaluate(X_train, y_train, X_test, y_test, model_name='fraud'):\n","    model = RandomForestClassifier(100, class_weight='balanced', random_state=42)\n","    model.fit(X_train, y_train)\n","    prob  = model.predict_proba(X_test)[:, 1]\n","    metrics = {\n","        'auc' : round(roc_auc_score(y_test, prob), 4),\n","        'ap'  : round(average_precision_score(y_test, prob), 4),\n","        'n_train': len(X_train),\n","    }\n","    return model, metrics\n","\n","# Initial champion\n","m1, met1 = train_and_evaluate(X_tr, y_tr, X_te, y_te)\n","k1 = registry.register('fraud', m1, met1, hash_dataset(X_tr, y_tr), 'Initial training')\n","registry.promote(k1)\n","print(f'Champion registered: {k1}  AUC={met1[\"auc\"]}')\n","\n","# New data arrives — retrain challenger\n","X_tr2 = np.vstack([X_tr, X_new])\n","y_tr2 = np.concatenate([y_tr, y_new])\n","m2, met2 = train_and_evaluate(X_tr2, y_tr2, X_te, y_te)\n","k2 = registry.register('fraud', m2, met2, hash_dataset(X_tr2, y_tr2), 'Month-2 retrain')\n","print(f'Challenger registered: {k2}  AUC={met2[\"auc\"]}')\n","\n","# Promote if challenger beats champion\n","champ_key = registry.champion('fraud')\n","champ_auc = registry.models[champ_key]['metrics']['auc']\n","if met2['auc'] > champ_auc:\n","    registry.promote(k2)\n","    print(f'New champion: {k2}  ({met2[\"auc\"]} > {champ_auc})')\n","else:\n","    print(f'Champion retained: {champ_key}  ({champ_auc} >= {met2[\"auc\"]})')"]},

  {"cell_type":"code","execution_count":null,"id":"s5-report","metadata":{},"outputs":[],
   "source":["# 5.5  Automated Evaluation Report\n","def generate_report(registry, model_name, X_test, y_test):\n","    champ_key = registry.champion(model_name)\n","    if not champ_key:\n","        return 'No champion model found'\n","    champ = registry.models[champ_key]\n","    model = champ['model']\n","    prob  = model.predict_proba(X_test)[:,1]\n","    pred  = (prob >= 0.5).astype(int)\n","\n","    report = {\n","        'report_time'    : datetime.utcnow().isoformat(),\n","        'champion_model' : champ_key,\n","        'data_hash'      : champ['data_hash'],\n","        'auc'            : round(roc_auc_score(y_test, prob), 4),\n","        'avg_precision'  : round(average_precision_score(y_test, prob), 4),\n","        'precision'      : round((pred * y_test).sum() / (pred.sum() + 1e-9), 4),\n","        'recall'         : round((pred * y_test).sum() / (y_test.sum() + 1e-9), 4),\n","        'n_test'         : len(y_test),\n","        'fraud_rate_test': round(y_test.mean(), 4),\n","    }\n","    return report\n","\n","report = generate_report(registry, 'fraud', X_te, y_te)\n","print('=== Automated Evaluation Report ===')\n","for k, v in report.items():\n","    print(f'  {k:20s}: {v}')\n","\n","print('\\nModel Registry Summary:')\n","print(registry.summary().to_string(index=False))"]},

  {"cell_type":"code","execution_count":null,"id":"s5-schedule","metadata":{},"outputs":[],
   "source":["# 5.6  Retraining Schedule Simulation\n","SCHEDULE_DAYS = 30      # retrain every 30 days OR on drift\n","DRIFT_PSI_THRESHOLD = 0.15\n","PERF_DROP_THRESHOLD = 0.02  # retrain if AUC drops by >0.02\n","\n","rng = np.random.default_rng(99)\n","results_schedule = []\n","baseline_auc = 0.935\n","last_retrain  = 0\n","\n","for day in range(1, 91):   # 90-day simulation\n","    drift    = day * 0.0008 + rng.normal(0, 0.0003)  # gradual drift\n","    curr_auc = max(0.7, baseline_auc - drift + rng.normal(0, 0.003))\n","    curr_psi = day * 0.002 + rng.normal(0, 0.001)\n","\n","    retrain_reason = None\n","    if day - last_retrain >= SCHEDULE_DAYS:\n","        retrain_reason = 'Scheduled'\n","    elif curr_psi > DRIFT_PSI_THRESHOLD:\n","        retrain_reason = 'Drift (PSI)'\n","    elif (baseline_auc - curr_auc) > PERF_DROP_THRESHOLD:\n","        retrain_reason = 'Perf drop'\n","\n","    if retrain_reason:\n","        last_retrain  = day\n","        baseline_auc  = curr_auc + 0.015  # retraining recovers performance\n","        curr_psi      = 0.0               # reset drift counter\n","\n","    results_schedule.append({'day': day, 'auc': curr_auc, 'psi': curr_psi,\n","                              'retrain': retrain_reason is not None,\n","                              'reason': retrain_reason})\n","\n","df_sched = pd.DataFrame(results_schedule)\n","retrain_days = df_sched[df_sched['retrain']]\n","print(f'Retraining events in 90 days: {len(retrain_days)}')\n","print(retrain_days[['day','auc','reason']].to_string(index=False))\n","\n","fig, ax = plt.subplots(figsize=(12, 4))\n","ax.plot(df_sched['day'], df_sched['auc'], color='#534AB7', linewidth=2)\n","for _, row in retrain_days.iterrows():\n","    ax.axvline(row['day'], color='#1D9E75', linestyle='--', alpha=0.7, linewidth=1.5)\n","    ax.text(row['day']+0.5, 0.72, row['reason'], fontsize=7, color='#1D9E75', rotation=90)\n","ax.axhline(0.90, linestyle=':', color='#D85A30', alpha=0.6, label='Alert threshold 0.90')\n","ax.set_xlabel('Day'); ax.set_ylabel('AUC')\n","ax.set_title('Model AUC Over 90 Days — Green lines = retraining events')\n","ax.legend(); ax.set_ylim(0.70, 0.96)\n","plt.tight_layout(); plt.show()"]},

